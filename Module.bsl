// #42 — get_balance: Остатки/обороты регистров бухгалтерии
Функция Инструмент_GetBalance(Аргументы)
        
        ИмяРегистра = Аргументы["register_name"];
        Если ИмяРегистра = Неопределено ИЛИ ИмяРегистра = "" Тогда
                ИмяРегистра = "Хозрасчетный";
        КонецЕсли;
        
        КодСчёта = Аргументы["account_code"];
        Если КодСчёта = Неопределено ИЛИ КодСчёта = "" Тогда
                ВызватьИсключение "Параметр account_code обязателен";
        КонецЕсли;
        
        ТипОстатков = Аргументы["balance_type"];
        Если ТипОстатков = Неопределено ИЛИ ТипОстатков = "" Тогда
                ТипОстатков = "balance";
        КонецЕсли;
        
        // Находим регистр бухгалтерии
        МДРегистр = Метаданные.РегистрыБухгалтерии.Найти(ИмяРегистра);
        Если МДРегистр = Неопределено Тогда
                ВызватьИсключение "Регистр бухгалтерии не найден: " + ИмяРегистра;
        КонецЕсли;
        
        Менеджер = РегистрыБухгалтерии[ИмяРегистра];
        
        // Определяем виртуальную таблицу
        Если ТипОстатков = "turnovers" Тогда
                ИмяВТ = "Обороты";
        ИначеЕсли ТипОстатков = "balance_and_turnovers" Тогда
                ИмяВТ = "ОстаткиИОбороты";
        Иначе
                ИмяВТ = "Остатки";
        КонецЕсли;
        
        // Строим текст запроса
        ТекстЗапроса = "ВЫБРАТЬ * ИЗ РегистрБухгалтерии." + ИмяРегистра + "." + ИмяВТ + "(";
        
        // Параметры виртуальной таблицы
        ПараметрыВТ = Новый Массив;
        
        // Период
        ПериодС = Аргументы["period_from"];
        ПериодПо = Аргументы["period_to"];
        Если ПериодС <> Неопределено И ПериодС <> "" Тогда
                ПараметрыВТ.Добавить("&ПериодС");
        Иначе
                ПараметрыВТ.Добавить("");
        КонецЕсли;
        Если ПериодПо <> Неопределено И ПериодПо <> "" Тогда
                ПараметрыВТ.Добавить("&ПериодПо");
        Иначе
                ПараметрыВТ.Добавить("");
        КонецЕсли;
        
        // Условие по счёту
        ПараметрыВТ.Добавить("Счёт = &Счёт");
        
        // Субконто — пока пустой
        ПараметрыВТ.Добавить("");
        
        ТекстЗапроса = ТекстЗапроса + СтрСоединить(ПараметрыВТ, ", ") + ")";
        
        // Дополнительные условия по измерениям
        ФильтрИзмерений = Аргументы["dimensions"];
        Если ФильтрИзмерений <> Неопределено И ТипЗнч(ФильтрИзмерений) = Тип("Соответствие") Тогда
                Условия = Новый Массив;
                Для Каждого КЗ Из ФильтрИзмерений Цикл
                        Условия.Добавить(КЗ.Ключ + " = &Изм_" + КЗ.Ключ);
                КонецЦикла;
                Если Условия.Количество() > 0 Тогда
                        ТекстЗапроса = ТекстЗапроса + " ГДЕ " + СтрСоединить(Условия, " И ");
                КонецЕсли;
        КонецЕсли;
        
        Запрос = Новый Запрос(ТекстЗапроса);
        
        // Параметры
        ПланСчетов = Метаданные.РегистрыБухгалтерии[ИмяРегистра].ПланСчетов;
        ИмяПланаСчетов = ПланСчетов.Имя;
        Счёт = ПланыСчетов[ИмяПланаСчетов].НайтиПоКоду(КодСчёта);
        Если Счёт.Пустая() Тогда
                ВызватьИсключение "Счёт не найден по коду: " + КодСчёта;
        КонецЕсли;
        Запрос.УстановитьПараметр("Счёт", Счёт);
        
        Если ПериодС <> Неопределено И ПериодС <> "" Тогда
                Запрос.УстановитьПараметр("ПериодС", ПреобразоватьДату(ПериодС));
        КонецЕсли;
        Если ПериодПо <> Неопределено И ПериодПо <> "" Тогда
                Запрос.УстановитьПараметр("ПериодПо", ПреобразоватьДату(ПериодПо));
        КонецЕсли;
        
        Если ФильтрИзмерений <> Неопределено И ТипЗнч(ФильтрИзмерений) = Тип("Соответствие") Тогда
                Для Каждого КЗ Из ФильтрИзмерений Цикл
                        Запрос.УстановитьПараметр("Изм_" + КЗ.Ключ, КЗ.Значение);
                КонецЦикла;
        КонецЕсли;
        
        Результат = Запрос.Выполнить();
        Если Результат.Пустой() Тогда
                Возврат ОбъектВJSON(Новый Соответствие("message", "Нет данных по заданным параметрам"));
        КонецЕсли;
        
        Строки = Новый Массив;
        Выборка = Результат.Выбрать();
        Пока Выборка.Следующий() Цикл
                Стр = Новый Соответствие;
                Для Каждого Колонка Из Результат.Колонки Цикл
                        Стр.Вставить(Колонка.Имя, ЗначениеДляJSON(Выборка[Колонка.Имя]));
                КонецЦикла;
                Строки.Добавить(Стр);
        КонецЦикла;
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("register", ИмяРегистра);
        Ответ.Вставить("account", КодСчёта);
        Ответ.Вставить("balance_type", ТипОстатков);
        Ответ.Вставить("rows", Строки);
        Ответ.Вставить("count", Строки.Количество());
        Возврат ОбъектВJSON(Ответ);
        
КонецФункции



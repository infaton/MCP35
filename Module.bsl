Функция Инструмент_ExecuteCode(Аргументы)
        
        Код = Аргументы["code"];
        
        // Логируем в журнал регистрации для аудита
        ЗаписьЖурналаРегистрации("INFATON.ExecuteCode",
                УровеньЖурналаРегистрации.Информация, , , Лев(Код, 500));
        
        Результат = "";
        
        // Код должен записать результат в переменную Результат
        Выполнить(Код);
        
        Если ТипЗнч(Результат) = Тип("Строка") Тогда
                Возврат Результат;
        Иначе
                Попытка
                        Возврат ОбъектВJSONКомпакт(Результат);
                Исключение
                        Возврат Строка(Результат);
                КонецПопытки;
        КонецЕсли;
        
КонецФункции


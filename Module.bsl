Процедура ДобавитьИнструмент(Инструменты, Имя, Описание, Свойства, Обязательные)
        Схема = Новый Соответствие;
        Схема.Вставить("type", "object");
        Схема.Вставить("properties", Свойства);
        Если Обязательные.Количество() > 0 Тогда
                Схема.Вставить("required", Обязательные);
        КонецЕсли;
        
        Инструмент = Новый Соответствие;
        Инструмент.Вставить("name", Имя);
        Инструмент.Вставить("description", Описание);
        Инструмент.Вставить("inputSchema", Схема);
        Инструменты.Добавить(Инструмент);
КонецПроцедуры


// Разбирает полное имя вида "Справочник.Номенклатура" на тип и имя
Функция РазобратьПолноеИмя(ПолноеИмя)
        
        Поз = СтрНайти(ПолноеИмя, ".");
        Если Поз = 0 Тогда
                Возврат Неопределено;
        КонецЕсли;
        
        Результат = Новый Структура;
        Результат.Вставить("Тип", Лев(ПолноеИмя, Поз - 1));
        Результат.Вставить("Имя", Сред(ПолноеИмя, Поз + 1));
        Возврат Результат;
        
КонецФункции

// Возвращает менеджер объекта (Справочники[...], Документы[...] и т.д.)
Функция ПолучитьМенеджерОбъекта(Тип, Имя)
        
        Если Тип = "Справочник" Тогда
                Возврат Справочники[Имя];
        ИначеЕсли Тип = "Документ" Тогда
                Возврат Документы[Имя];
        ИначеЕсли Тип = "ПланСчетов" Тогда
                Возврат ПланыСчетов[Имя];
        ИначеЕсли Тип = "ПланВидовХарактеристик" Тогда
                Возврат ПланыВидовХарактеристик[Имя];
        ИначеЕсли Тип = "ПланОбмена" Тогда
                Возврат ПланыОбмена[Имя];
        Иначе
                Возврат Неопределено;
        КонецЕсли;
        
КонецФункции

// Описание реквизита метаданных
Функция ОписаниеРеквизита(Реквизит)
        
        РА = Новый Соответствие;
        РА.Вставить("name", Реквизит.Имя);
        РА.Вставить("synonym", Реквизит.Синоним);
        
        // Тип
        ОписаниеТипа = Реквизит.Тип;
        Типы = Новый Массив;
        Для Каждого Т Из ОписаниеТипа.Типы() Цикл
                Типы.Добавить(Строка(Т));
        КонецЦикла;
        РА.Вставить("types", Типы);
        
        // Длина строки (если есть)
        Попытка
                Если ОписаниеТипа.КвалификаторыСтроки <> Неопределено Тогда
                        РА.Вставить("string_length", ОписаниеТипа.КвалификаторыСтроки.Длина);
                КонецЕсли;
        Исключение
        КонецПопытки;
        
        Возврат РА;
        
КонецФункции

// Преобразование любого значения 1С в JSON-совместимый тип
Функция ЗначениеДляJSON(Значение)
        
        Если Значение = Неопределено Или Значение = NULL Тогда
                Возврат Неопределено;
        КонецЕсли;
        
        ТипЗначения = ТипЗнч(Значение);
        
        Если ТипЗначения = Тип("Строка")
                Или ТипЗначения = Тип("Число")
                Или ТипЗначения = Тип("Булево") Тогда
                Возврат Значение;
                
        ИначеЕсли ТипЗначения = Тип("Дата") Тогда
                Возврат Формат(Значение, "ДФ=yyyy-MM-ddTHH:mm:ss");
                
        ИначеЕсли ТипЗначения = Тип("УникальныйИдентификатор") Тогда
                Возврат Строка(Значение);
        Иначе
                // Для ссылочных типов пытаемся получить представление и UUID
                Попытка
                        МД = Значение.Метаданные();
                        Рез = Новый Соответствие;
                        Рез.Вставить("_ref", Строка(Значение));
                        Рез.Вставить("_type", МД.ПолноеИмя());
                        Попытка
                                Рез.Вставить("_guid", Строка(Значение.УникальныйИдентификатор()));
                        Исключение
                        КонецПопытки;
                        Возврат Рез;
                Исключение
                        Возврат Строка(Значение);
                КонецПопытки;
        КонецЕсли;
        
КонецФункции

// Сериализация объекта 1С (справочник, документ) в Соответствие
Функция СериализоватьОбъект(Объект, ПолноеИмя)
        
        Результат = Новый Соответствие;
        
        МДОбъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
        
        // UUID
        Попытка
                Результат.Вставить("_guid", Строка(Объект.Ссылка.УникальныйИдентификатор()));
        Исключение
        КонецПопытки;
        
        Результат.Вставить("_type", ПолноеИмя);
        
        // Стандартные реквизиты
        Попытка Результат.Вставить("Код", Объект.Код); Исключение КонецПопытки;
        Попытка Результат.Вставить("Наименование", Объект.Наименование); Исключение КонецПопытки;
        Попытка Результат.Вставить("Дата", Формат(Объект.Дата, "ДФ=yyyy-MM-ddTHH:mm:ss")); Исключение КонецПопытки;
        Попытка Результат.Вставить("Номер", Объект.Номер); Исключение КонецПопытки;
        Попытка Результат.Вставить("ПометкаУдаления", Объект.ПометкаУдаления); Исключение КонецПопытки;
        Попытка Результат.Вставить("Проведен", Объект.Проведен); Исключение КонецПопытки;
        Попытка Результат.Вставить("Родитель", ЗначениеДляJSON(Объект.Родитель)); Исключение КонецПопытки;
        Попытка Результат.Вставить("Владелец", ЗначениеДляJSON(Объект.Владелец)); Исключение КонецПопытки;
        
        // Пользовательские реквизиты
        Если МДОбъект <> Неопределено Тогда
                Попытка
                        Для Каждого Рекв Из МДОбъект.Реквизиты Цикл
                                Попытка
                                        Результат.Вставить(Рекв.Имя, ЗначениеДляJSON(Объект[Рекв.Имя]));
                                Исключение
                                КонецПопытки;
                        КонецЦикла;
                Исключение
                КонецПопытки;
                
                // Табличные части
                Попытка
                        Для Каждого ТабЧасть Из МДОбъект.ТабличныеЧасти Цикл
                                СтрокиТЧ = Новый Массив;
                                Для Каждого СтрокаТЧ Из Объект[ТабЧасть.Имя] Цикл
                                        СтрокаДанных = Новый Соответствие;
                                        СтрокаДанных.Вставить("НомерСтроки", СтрокаТЧ.НомерСтроки);
                                        Для Каждого Рекв Из ТабЧасть.Реквизиты Цикл
                                                Попытка
                                                        СтрокаДанных.Вставить(Рекв.Имя, ЗначениеДляJSON(СтрокаТЧ[Рекв.Имя]));
                                                Исключение
                                                КонецПопытки;
                                        КонецЦикла;
                                        СтрокиТЧ.Добавить(СтрокаДанных);
                                КонецЦикла;
                                Результат.Вставить(ТабЧасть.Имя, СтрокиТЧ);
                        КонецЦикла;
                Исключение
                КонецПопытки;
        КонецЕсли;
        
        Возврат Результат;
        
КонецФункции

// Заполнение реквизитов объекта из Соответствия
Процедура ЗаполнитьРеквизитыОбъекта(Объект, Реквизиты, ПолноеИмя)
        
        Для Каждого КЗ Из Реквизиты Цикл
                ИмяРеквизита = КЗ.Ключ;
                Значение = КЗ.Значение;
                
                // Пропускаем служебные поля
                Если СтрНачинаетсяС(ИмяРеквизита, "_") Тогда Продолжить; КонецЕсли;
                
                Попытка
                        УстановитьЗначениеРеквизита(Объект, ИмяРеквизита, Значение);
                Исключение
                КонецПопытки;
        КонецЦикла;
        
КонецПроцедуры

// Установка значения реквизита с преобразованием типов
Процедура УстановитьЗначениеРеквизита(Объект, ИмяРеквизита, Значение)
        
        // Если имя заканчивается на _guid — это ссылочный тип, нужно найти объект
        Если СтрЗаканчиваетсяНа(ИмяРеквизита, "_guid") Тогда
                // Формат: ИмяРеквизита_guid = "UUID", ожидаем что реквизит = ИмяРеквизита
                НастоящееИмя = Лев(ИмяРеквизита, СтрДлина(ИмяРеквизита) - 5);
                // Определяем тип реквизита из метаданных
                МД = Объект.Метаданные();
                Для Каждого Рекв Из МД.Реквизиты Цикл
                        Если Рекв.Имя = НастоящееИмя Тогда
                                Типы = Рекв.Тип.Типы();
                                Если Типы.Количество() > 0 Тогда
                                        ТипСсылки = Типы[0];
                                        МДСсылки = Метаданные.НайтиПоТипу(ТипСсылки);
                                        Если МДСсылки <> Неопределено Тогда
                                                Части = РазобратьПолноеИмя(МДСсылки.ПолноеИмя());
                                                Менеджер = ПолучитьМенеджерОбъекта(Части.Тип, Части.Имя);
                                                Если Менеджер <> Неопределено Тогда
                                                        УИД = Новый УникальныйИдентификатор(Значение);
                                                        Объект[НастоящееИмя] = Менеджер.ПолучитьСсылку(УИД);
                                                        Возврат;
                                                КонецЕсли;
                                        КонецЕсли;
                                КонецЕсли;
                                Прервать;
                        КонецЕсли;
                КонецЦикла;
                Возврат;
        КонецЕсли;
        
        // Обычное присваивание
        Объект[ИмяРеквизита] = Значение;
        
КонецПроцедуры


Функция СтрПовторить(ПовторяемыйФрагмент,КоличествоПовторов) 
МассивПустыхСтрок=новый массив(КоличествоПовторов + 1);	
Результат = СтрСоединить(МассивПустыхСтрок, ПовторяемыйФрагмент); 
Возврат Результат;
КонецФункции


// Преобразование строки даты в Дату 1С (поддержка ISO 8601 и YYYYMMDD)
Функция ПреобразоватьДату(СтрокаДаты)
	Если СтрокаДаты = Неопределено Или ПустаяСтрока(СтрокаДаты) Тогда
		Возврат Неопределено;
	КонецЕсли;
	
	// Приводим к строке если число
	Стр = СокрЛП(Строка(СтрокаДаты));
	
	// Убираем суффикс часового пояса (Z, +05:00, -03:00)
	Стр = СтрЗаменить(Стр, "Z", "");
	ПозицияПлюс = СтрНайти(Стр, "+");
	Если ПозицияПлюс > 10 Тогда
		Стр = Лев(Стр, ПозицияПлюс - 1);
	КонецЕсли;
	// Минус в конце (часовой пояс -XX:XX после времени)
	ДлинаСтр = СтрДлина(Стр);
	Если ДлинаСтр > 19 Тогда
		// Обрезаем хвост (пояс)
		Стр = Лев(Стр, 19);
	КонецЕсли;
	
	Попытка
		// Формат ISO 8601: 2026-05-14T10:30:00
		Если СтрНайти(Стр, "T") > 0 Или СтрНайти(Стр, "t") > 0 Тогда
			ЧастиДТ = СтрРазделить(ВРег(Стр), "T");
			Если ЧастиДТ.Количество() < 2 Тогда Возврат Неопределено; КонецЕсли;
			ЧастиДаты = СтрРазделить(ЧастиДТ[0], "-");
			Если ЧастиДаты.Количество() < 3 Тогда Возврат Неопределено; КонецЕсли;
			ВремяСтр = ЧастиДТ[1];
			// Отсекаем дробные секунды (.123)
			ПозТочки = СтрНайти(ВремяСтр, ".");
			Если ПозТочки > 0 Тогда ВремяСтр = Лев(ВремяСтр, ПозТочки - 1); КонецЕсли;
			ЧастиВремени = СтрРазделить(ВремяСтр, ":");
			Год = Формат(Число(ЧастиДаты[0]), "ЧЦ=4; ЧВН=; ЧГ=");
			Мес = Формат(Число(ЧастиДаты[1]), "ЧЦ=2; ЧВН=; ЧГ=");
			День = Формат(Число(ЧастиДаты[2]), "ЧЦ=2; ЧВН=; ЧГ=");
			Час = Формат(Число(ЧастиВремени[0]), "ЧЦ=2; ЧВН=; ЧГ=");
			Мин = ?(ЧастиВремени.Количество() > 1, Формат(Число(ЧастиВремени[1]), "ЧЦ=2; ЧВН=; ЧГ="), "00");
			Сек = ?(ЧастиВремени.Количество() > 2, Формат(Число(ЧастиВремени[2]), "ЧЦ=2; ЧВН=; ЧГ="), "00");
			Возврат Дата(Год + Мес + День + Час + Мин + Сек);
		КонецЕсли;
		
		// Формат YYYYMMDD (8 цифр без разделителей)
		Если СтрДлина(Стр) = 8 И СтрНайти(Стр, "-") = 0 И СтрНайти(Стр, ".") = 0 Тогда
			Возврат Дата(Стр + "000000");
		КонецЕсли;
		
		// Формат YYYYMMDDHHMMSS (14 цифр)
		Если СтрДлина(Стр) = 14 И СтрНайти(Стр, "-") = 0 Тогда
			Возврат Дата(Стр);
		КонецЕсли;
		
		// Формат YYYY-MM-DD
		Если СтрДлина(Стр) = 10 И СтрНайти(Стр, "-") > 0 Тогда
			ЧастиДаты = СтрРазделить(Стр, "-");
			Если ЧастиДаты.Количество() = 3 Тогда
				Год = Формат(Число(ЧастиДаты[0]), "ЧЦ=4; ЧВН=; ЧГ=");
				Мес = Формат(Число(ЧастиДаты[1]), "ЧЦ=2; ЧВН=; ЧГ=");
				День = Формат(Число(ЧастиДаты[2]), "ЧЦ=2; ЧВН=; ЧГ=");
				Возврат Дата(Год + Мес + День + "000000");
			КонецЕсли;
		КонецЕсли;
		
		// Формат DD.MM.YYYY (русский)
		Если СтрДлина(Стр) = 10 И СтрНайти(Стр, ".") > 0 Тогда
			ЧастиДаты = СтрРазделить(Стр, ".");
			Если ЧастиДаты.Количество() = 3 Тогда
				Год = Формат(Число(ЧастиДаты[2]), "ЧЦ=4; ЧВН=; ЧГ=");
				Мес = Формат(Число(ЧастиДаты[1]), "ЧЦ=2; ЧВН=; ЧГ=");
				День = Формат(Число(ЧастиДаты[0]), "ЧЦ=2; ЧВН=; ЧГ=");
				Возврат Дата(Год + Мес + День + "000000");
			КонецЕсли;
		КонецЕсли;
		
		Возврат Неопределено;
	Исключение
		Возврат Неопределено;
	КонецПопытки;
КонецФункции


// Преобразование значения для записи в регистр с учётом ссылочных типов
Функция ПреобразоватьЗначениеДляРегистра(МДИзмерение, Значение)
        Если Значение = Неопределено Тогда Возврат Неопределено; КонецЕсли;
        
        // Проверяем, является ли тип ссылочным
        Типы = МДИзмерение.Тип.Типы();
        Для Каждого Тип Из Типы Цикл
                МДТипа = Метаданные.НайтиПоТипу(Тип);
                Если МДТипа <> Неопределено Тогда
                        // Это ссылочный тип — пробуем преобразовать GUID
                        Попытка
                                Части = РазобратьПолноеИмя(МДТипа.ПолноеИмя());
                                Менеджер = ПолучитьМенеджерОбъекта(Части.Тип, Части.Имя);
                                Если Менеджер <> Неопределено Тогда
                                        УИД = Новый УникальныйИдентификатор(Значение);
                                        Возврат Менеджер.ПолучитьСсылку(УИД);
                                КонецЕсли;
                        Исключение
                        КонецПопытки;
                КонецЕсли;
        КонецЦикла;
        
        Возврат Значение;
КонецФункции

// Преобразование значения по метаданным регистра (универсальное)
Функция ПреобразоватьЗначениеПоМетаданным(МДРегистр, ИмяПоля, Значение)
        
        // Ищем поле среди измерений
        Для Каждого Изм Из МДРегистр.Измерения Цикл
                Если Изм.Имя = ИмяПоля Тогда
                        Возврат ПреобразоватьЗначениеДляРегистра(Изм, Значение);
                КонецЕсли;
        КонецЦикла;
        
        // Ищем среди ресурсов
        Для Каждого Рес Из МДРегистр.Ресурсы Цикл
                Если Рес.Имя = ИмяПоля Тогда
                        Возврат ПреобразоватьЗначениеДляРегистра(Рес, Значение);
                КонецЕсли;
        КонецЦикла;
        
        // Ищем среди реквизитов
        Для Каждого Рекв Из МДРегистр.Реквизиты Цикл
                Если Рекв.Имя = ИмяПоля Тогда
                        Возврат ПреобразоватьЗначениеДляРегистра(Рекв, Значение);
                КонецЕсли;
        КонецЦикла;
        
        Возврат Значение;
КонецФункции

// Вспомогательная: свойство-массив для описания инструментов
Функция СвойствоМассив(Описание)
        Св = Новый Соответствие;
        Св.Вставить("type", "array");
        Св.Вставить("description", Описание);
        Св.Вставить("items", Новый Соответствие); // items: { type: "object" }
        Св["items"].Вставить("type", "object");
        Возврат Св;
КонецФункции

// Диспетчер: вызов инструмента по имени (для execute_batch)
Функция ВыполнитьИнструментПоИмени(ИмяИнструмента, Аргументы)
        
        // Группа А: Метаданные
        Если ИмяИнструмента = "get_metadata_tree" Тогда Возврат Инструмент_GetMetadataTree(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_object_metadata" Тогда Возврат Инструмент_GetObjectMetadata(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_object_attributes" Тогда Возврат Инструмент_GetObjectAttributes(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_object_tabular_sections" Тогда Возврат Инструмент_GetObjectTabularSections(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_enum_values" Тогда Возврат Инструмент_GetEnumValues(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_register_dimensions" Тогда Возврат Инструмент_GetRegisterDimensions(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_document_movements" Тогда Возврат Инструмент_GetDocumentMovements(Аргументы);
        ИначеЕсли ИмяИнструмента = "search_metadata" Тогда Возврат Инструмент_SearchMetadata(Аргументы);
        // Группа Б: Чтение данных
        ИначеЕсли ИмяИнструмента = "execute_query" Тогда Возврат Инструмент_ExecuteQuery(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_object_by_ref" Тогда Возврат Инструмент_GetObjectByRef(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_list" Тогда Возврат Инструмент_GetList(Аргументы);
        ИначеЕсли ИмяИнструмента = "find_by_code" Тогда Возврат Инструмент_FindByCode(Аргументы);
        ИначеЕсли ИмяИнструмента = "find_by_name" Тогда Возврат Инструмент_FindByName(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_register_records" Тогда Возврат Инструмент_GetRegisterRecords(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_document_list" Тогда Возврат Инструмент_GetDocumentList(Аргументы);
        // Группа В: Запись данных
        ИначеЕсли ИмяИнструмента = "create_object" Тогда Возврат Инструмент_CreateObject(Аргументы);
        ИначеЕсли ИмяИнструмента = "update_object" Тогда Возврат Инструмент_UpdateObject(Аргументы);
        ИначеЕсли ИмяИнструмента = "delete_object" Тогда Возврат Инструмент_DeleteObject(Аргументы);
        ИначеЕсли ИмяИнструмента = "post_document" Тогда Возврат Инструмент_PostDocument(Аргументы);
        ИначеЕсли ИмяИнструмента = "unpost_document" Тогда Возврат Инструмент_UnpostDocument(Аргументы);
        ИначеЕсли ИмяИнструмента = "copy_object" Тогда Возврат Инструмент_CopyObject(Аргументы);
        ИначеЕсли ИмяИнструмента = "set_attribute" Тогда Возврат Инструмент_SetAttribute(Аргументы);
        // Группа Г: Код и отчёты
        ИначеЕсли ИмяИнструмента = "execute_code" Тогда Возврат Инструмент_ExecuteCode(Аргументы);
        ИначеЕсли ИмяИнструмента = "evaluate_expression" Тогда Возврат Инструмент_EvaluateExpression(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_module_text" Тогда Возврат Инструмент_GetModuleText(Аргументы);
        ИначеЕсли ИмяИнструмента = "generate_report" Тогда Возврат Инструмент_GenerateReport(Аргументы);
        // Группа Д: Администрирование
        ИначеЕсли ИмяИнструмента = "get_active_users" Тогда Возврат Инструмент_GetActiveUsers(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_event_log" Тогда Возврат Инструмент_GetEventLog(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_locks" Тогда Возврат Инструмент_GetLocks(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_server_info" Тогда Возврат Инструмент_GetServerInfo(Аргументы);
        ИначеЕсли ИмяИнструмента = "check_references" Тогда Возврат Инструмент_CheckReferences(Аргументы);
        ИначеЕсли ИмяИнструмента = "run_scheduled_job" Тогда Возврат Инструмент_RunScheduledJob(Аргументы);
        // Группа Е: Интеграция
        ИначеЕсли ИмяИнструмента = "exchange_execute" Тогда Возврат Инструмент_ExchangeExecute(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_exchange_log" Тогда Возврат Инструмент_GetExchangeLog(Аргументы);
        ИначеЕсли ИмяИнструмента = "import_data" Тогда Возврат Инструмент_ImportData(Аргументы);
        // Группа Ж: Новые v2.0
        ИначеЕсли ИмяИнструмента = "fill_on_basis" Тогда Возврат Инструмент_FillOnBasis(Аргументы);
        ИначеЕсли ИмяИнструмента = "write_register_records" Тогда Возврат Инструмент_WriteRegisterRecords(Аргументы);
        ИначеЕсли ИмяИнструмента = "update_tabular_section" Тогда Возврат Инструмент_UpdateTabularSection(Аргументы);
        ИначеЕсли ИмяИнструмента = "subscribe_events" Тогда Возврат Инструмент_SubscribeEvents(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_changes_since" Тогда Возврат Инструмент_GetChangesSince(Аргументы);
        // Группа З: Новые v2.1
        ИначеЕсли ИмяИнструмента = "get_balance" Тогда Возврат Инструмент_GetBalance(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_register_totals" Тогда Возврат Инструмент_GetRegisterTotals(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_accounting_entries" Тогда Возврат Инструмент_GetAccountingEntries(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_related_documents" Тогда Возврат Инструмент_GetRelatedDocuments(Аргументы);
        ИначеЕсли ИмяИнструмента = "validate_document" Тогда Возврат Инструмент_ValidateDocument(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_form_structure" Тогда Возврат Инструмент_GetFormStructure(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_rights" Тогда Возврат Инструмент_GetRights(Аргументы);
        ИначеЕсли ИмяИнструмента = "find_duplicates" Тогда Возврат Инструмент_FindDuplicates(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_print_form" Тогда Возврат Инструмент_GetPrintForm(Аргументы);
        ИначеЕсли ИмяИнструмента = "get_configuration_extensions" Тогда Возврат Инструмент_GetConfigurationExtensions(Аргументы);

        Иначе
                ВызватьИсключение "Неизвестный инструмент: " + ИмяИнструмента;
        КонецЕсли;
        
КонецФункции



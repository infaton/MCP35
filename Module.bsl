Функция Инструмент_CheckReferences(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        СтрокаGUID = Аргументы["guid"];
        
        Части = РазобратьПолноеИмя(ПолноеИмя);
        Менеджер = ПолучитьМенеджерОбъекта(Части.Тип, Части.Имя);
        УИД = Новый УникальныйИдентификатор(СтрокаGUID);
        Ссылка = Менеджер.ПолучитьСсылку(УИД);
        
        МассивСсылок = Новый Массив;
        МассивСсылок.Добавить(Ссылка);
        
        ТаблицаСсылок = НайтиПоСсылкам(МассивСсылок);
        
        Найденные = Новый Массив;
        Для Каждого Строка Из ТаблицаСсылок Цикл
                Эл = Новый Соответствие;
                Эл.Вставить("referencing_object", Строка(Строка.Данные));
                Эл.Вставить("metadata", Строка.Метаданные.ПолноеИмя());
                Попытка
                        Эл.Вставить("guid", Строка(Строка.Данные.УникальныйИдентификатор()));
                Исключение
                КонецПопытки;
                Найденные.Добавить(Эл);
        КонецЦикла;
        
        Результат = Новый Соответствие;
        Результат.Вставить("references", Найденные);
        Результат.Вставить("total", Найденные.Количество());
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции

Функция Инструмент_RunScheduledJob(Аргументы)
        
        ИмяЗадания = Аргументы["job_name"];
        
        // Находим метаданные регламентного задания
        МДЗадания = Метаданные.РегламентныеЗадания.Найти(ИмяЗадания);
        Если МДЗадания = Неопределено Тогда
                // Пробуем поиск по синониму
                Для Каждого МД Из Метаданные.РегламентныеЗадания Цикл
                        Если МД.Имя = ИмяЗадания Или МД.Синоним = ИмяЗадания Тогда
                                МДЗадания = МД;
                                Прервать;
                        КонецЕсли;
                КонецЦикла;
        КонецЕсли;
        
        Если МДЗадания = Неопределено Тогда
                // Выводим список доступных заданий
                Список = Новый Массив;
                Для Каждого МД Из Метаданные.РегламентныеЗадания Цикл
                        Список.Добавить(МД.Имя + " (" + МД.Синоним + ")");
                КонецЦикла;
                Возврат "Регламентное задание '" + ИмяЗадания + "' не найдено. Доступные задания: " + СтрСоединить(Список, ", ");
        КонецЕсли;
        
        // Получаем задание и выполняем
        Отбор = Новый Структура("Метаданные", МДЗадания);
        Задания = РегламентныеЗадания.ПолучитьРегламентныеЗадания(Отбор);
        
        Если Задания.Количество() = 0 Тогда
                Возврат "Экземпляр регламентного задания '" + ИмяЗадания + "' не найден";
        КонецЕсли;
        
        Задание = Задания[0];
        ФоновоеЗадание = Задание.ВыполнитьСейчас();
        ФоновоеЗадание.ОжидатьЗавершения(60); // таймаут 60 сек
        
        Результат = Новый Соответствие;
        Результат.Вставить("success", Истина);
        Результат.Вставить("job_name", ИмяЗадания);
        Результат.Вставить("state", Строка(ФоновоеЗадание.Состояние));
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции


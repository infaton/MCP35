Функция Инструмент_GetObjectMetadata(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        МДОбъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
        Если МДОбъект = Неопределено Тогда
                Возврат "Объект метаданных не найден: " + ПолноеИмя;
        КонецЕсли;
        
        Результат = Новый Соответствие;
        Результат.Вставить("full_name", ПолноеИмя);
        Результат.Вставить("name", МДОбъект.Имя);
        Результат.Вставить("synonym", МДОбъект.Синоним);
        Результат.Вставить("comment", МДОбъект.Комментарий);
        
        // Реквизиты
        Попытка
                Реквизиты = Новый Массив;
                Для Каждого Рекв Из МДОбъект.Реквизиты Цикл
                        Реквизиты.Добавить(ОписаниеРеквизита(Рекв));
                КонецЦикла;
                Результат.Вставить("attributes", Реквизиты);
        Исключение
        КонецПопытки;
        
        // Стандартные реквизиты
        Попытка
                Стандартные = Новый Массив;
                Для Каждого Рекв Из МДОбъект.СтандартныеРеквизиты Цикл
                        СР = Новый Соответствие;
                        СР.Вставить("name", Рекв.Имя);
                        СР.Вставить("synonym", Рекв.Синоним);
                        Стандартные.Добавить(СР);
                КонецЦикла;
                Результат.Вставить("standard_attributes", Стандартные);
        Исключение
        КонецПопытки;
        
        // Табличные части
        Попытка
                ТЧ = Новый Массив;
                Для Каждого ТабЧасть Из МДОбъект.ТабличныеЧасти Цикл
                        ТЧОписание = Новый Соответствие;
                        ТЧОписание.Вставить("name", ТабЧасть.Имя);

Функция СтрМассив(Зн1, Зн2 = Неопределено, Зн3 = Неопределено, Зн4 = Неопределено)
        Массив = Новый Массив;
        Массив.Добавить(Зн1);
        Если Зн2 <> Неопределено Тогда Массив.Добавить(Зн2); КонецЕсли;
        Если Зн3 <> Неопределено Тогда Массив.Добавить(Зн3); КонецЕсли;
        Если Зн4 <> Неопределено Тогда Массив.Добавить(Зн4); КонецЕсли;
        Возврат Массив;
КонецФункции


Функция Инструмент_GetRegisterRecords(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        МаксСтрок = Аргументы["max_rows"];
        Если МаксСтрок = Неопределено Или МаксСтрок = 0 Тогда МаксСтрок = 100; КонецЕсли;
        ПериодС = Аргументы["period_from"];
        ПериодПо = Аргументы["period_to"];
        Фильтр = Аргументы["filter"];
        
        ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ " + Формат(МаксСтрок, "ЧГ=") + " *
        |ИЗ " + ПолноеИмя + " КАК Р";
        
        Условия = Новый Массив;
        
        Если ЗначениеЗаполнено(ПериодС) Тогда
                Условия.Добавить("Р.Период >= ДАТАВРЕМЯ(" + Лев(ПериодС,4) + "," + Сред(ПериодС,5,2) + "," + Прав(ПериодС,2) + ")");
        КонецЕсли;
        Если ЗначениеЗаполнено(ПериодПо) Тогда
                Условия.Добавить("Р.Период <= ДАТАВРЕМЯ(" + Лев(ПериодПо,4) + "," + Сред(ПериодПо,5,2) + "," + Прав(ПериодПо,2) + ",23,59,59)");
        КонецЕсли;
        Если ЗначениеЗаполнено(Фильтр) Тогда
                Условия.Добавить(Фильтр);
        КонецЕсли;
        
        Если Условия.Количество() > 0 Тогда
                ТекстЗапроса = ТекстЗапроса + "
                |ГДЕ " + СтрСоединить(Условия, " И ");
        КонецЕсли;
        
        Запрос = Новый Запрос;
        Запрос.Текст = ТекстЗапроса;
        РезультатЗапроса = Запрос.Выполнить();
        Выборка = РезультатЗапроса.Выбрать();
        
        Строки = Новый Массив;
        Пока Выборка.Следующий() Цикл
                Строка = Новый Соответствие;
                Для Каждого Кол Из РезультатЗапроса.Колонки Цикл
                        Строка.Вставить(Кол.Имя, ЗначениеДляJSON(Выборка[Кол.Имя]));
                КонецЦикла;
                Строки.Добавить(Строка);
        КонецЦикла;
        
        Возврат ОбъектВJSONКомпакт(Строки);
        
КонецФункции

Функция Инструмент_GetDocumentList(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        Топ = Аргументы["top"];
        Если Топ = Неопределено Или Топ = 0 Тогда Топ = 50; КонецЕсли;
        ПериодС = Аргументы["period_from"];
        ПериодПо = Аргументы["period_to"];
        ТолькоПроведённые = Аргументы["posted_only"];
        
        ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ " + Формат(Топ, "ЧГ=") + "
        |  Т.Ссылка.УникальныйИдентификатор() КАК GUID,
        |  Т.Номер КАК Номер,
        |  Т.Дата КАК Дата,
        |  Т.Проведен КАК Проведен,
        |  Т.ПометкаУдаления КАК ПометкаУдаления
        |ИЗ " + ПолноеИмя + " КАК Т";
        
        Условия = Новый Массив;
        Если ЗначениеЗаполнено(ПериодС) Тогда
                Условия.Добавить("Т.Дата >= ДАТАВРЕМЯ(" + Лев(ПериодС,4) + "," + Сред(ПериодС,5,2) + "," + Прав(ПериодС,2) + ")");
        КонецЕсли;
        Если ЗначениеЗаполнено(ПериодПо) Тогда
                Условия.Добавить("Т.Дата <= ДАТАВРЕМЯ(" + Лев(ПериодПо,4) + "," + Сред(ПериодПо,5,2) + "," + Прав(ПериодПо,2) + ",23,59,59)");
        КонецЕсли;
        Если ТолькоПроведённые = Истина Тогда
                Условия.Добавить("Т.Проведен");
        КонецЕсли;
        
        Если Условия.Количество() > 0 Тогда
                ТекстЗапроса = ТекстЗапроса + "
                |ГДЕ " + СтрСоединить(Условия, " И ");
        КонецЕсли;
        
        ТекстЗапроса = ТекстЗапроса + "
        |УПОРЯДОЧИТЬ ПО Т.Дата УБЫВ";
        
        Запрос = Новый Запрос;
        Запрос.Текст = ТекстЗапроса;
        РезультатЗапроса = Запрос.Выполнить();
        Выборка = РезультатЗапроса.Выбрать();
        
        Строки = Новый Массив;
        Пока Выборка.Следующий() Цикл
                Строка = Новый Соответствие;
                Для Каждого Кол Из РезультатЗапроса.Колонки Цикл
                        Строка.Вставить(Кол.Имя, ЗначениеДляJSON(Выборка[Кол.Имя]));
                КонецЦикла;
                Строки.Добавить(Строка);
        КонецЦикла;
        
        Возврат ОбъектВJSONКомпакт(Строки);
        
КонецФункции

#КонецОбласти



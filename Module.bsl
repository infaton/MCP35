Функция Инструмент_ExecuteQuery(Аргументы)
        
        ТекстЗапроса = Аргументы["query"];
        МаксСтрок = Аргументы["max_rows"];
        Если МаксСтрок = Неопределено Или МаксСтрок = 0 Тогда
                МаксСтрок = 100;
        КонецЕсли;
        Если МаксСтрок > 1000 Тогда
                МаксСтрок = 1000;
        КонецЕсли;
        
        Запрос = Новый Запрос;
        Запрос.Текст = ТекстЗапроса;
        
        РезультатЗапроса = Запрос.Выполнить();
        Колонки = РезультатЗапроса.Колонки;
        Выборка = РезультатЗапроса.Выбрать();
        
        Строки = Новый Массив;
        Счётчик = 0;
        Пока Выборка.Следующий() И Счётчик < МаксСтрок Цикл
                Строка = Новый Соответствие;
                Для Каждого Кол Из Колонки Цикл
                        Значение = Выборка[Кол.Имя];
                        Строка.Вставить(Кол.Имя, ЗначениеДляJSON(Значение));
                КонецЦикла;
                Строки.Добавить(Строка);
                Счётчик = Счётчик + 1;
        КонецЦикла;
        
        Результат = Новый Соответствие;
        Результат.Вставить("rows", Строки);
        Результат.Вставить("count", Счётчик);
        Результат.Вставить("truncated", Счётчик >= МаксСтрок);
        
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции

Функция Инструмент_GetObjectByRef(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        СтрокаGUID = Аргументы["guid"];
        
        Части = РазобратьПолноеИмя(ПолноеИмя);
        Если Части = Неопределено Тогда
                Возврат "Некорректное полное имя: " + ПолноеИмя;
        КонецЕсли;
        
        Менеджер = ПолучитьМенеджерОбъекта(Части.Тип, Части.Имя);
        Если Менеджер = Неопределено Тогда
                Возврат "Не удалось получить менеджер для: " + ПолноеИмя;
        КонецЕсли;
        
        УИД = Новый УникальныйИдентификатор(СтрокаGUID);
        Ссылка = Менеджер.ПолучитьСсылку(УИД);
        
        Если Ссылка.ПустаяСсылка() Или Не ЗначениеЗаполнено(Ссылка) Тогда
                Возврат "Объект не найден: " + ПолноеИмя + " / " + СтрокаGUID;
        КонецЕсли;
        
        Объект = Ссылка.ПолучитьОбъект();
        Если Объект = Неопределено Тогда
                Возврат "Объект не существует в базе: " + СтрокаGUID;
        КонецЕсли;
        
        Возврат ОбъектВJSONКомпакт(СериализоватьОбъект(Объект, ПолноеИмя));
        
КонецФункции

Функция Инструмент_GetList(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        Топ = Аргументы["top"];
        Если Топ = Неопределено Или Топ = 0 Тогда Топ = 50; КонецЕсли;
        Если Топ > 500 Тогда Топ = 500; КонецЕсли;
        Пропустить = Аргументы["skip"];
        Если Пропустить = Неопределено Тогда Пропустить = 0; КонецЕсли;
        Фильтр = Аргументы["filter"];
        
        ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ " + Формат(Топ + Пропустить, "ЧГ=") + "
        |  Т.Ссылка КАК Ссылка,
        |  Т.Ссылка.УникальныйИдентификатор() КАК GUID";
        
        // Пробуем добавить Код и Наименование
        МДОбъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
        Если МДОбъект <> Неопределено Тогда
                Попытка
                        Для Каждого СР Из МДОбъект.СтандартныеРеквизиты Цикл
                                Если СР.Имя = "Код" Тогда
                                        ТекстЗапроса = ТекстЗапроса + ",
                                        |  Т.Код КАК Код";
                                КонецЕсли;
                                Если СР.Имя = "Наименование" Тогда
                                        ТекстЗапроса = ТекстЗапроса + ",
                                        |  Т.Наименование КАК Наименование";
                                КонецЕсли;
                                Если СР.Имя = "Дата" Тогда
                                        ТекстЗапроса = ТекстЗапроса + ",
                                        |  Т.Дата КАК Дата";
                                КонецЕсли;
                                Если СР.Имя = "Номер" Тогда
                                        ТекстЗапроса = ТекстЗапроса + ",
                                        |  Т.Номер КАК Номер";
                                КонецЕсли;
                        КонецЦикла;
                Исключение
                КонецПопытки;
        КонецЕсли;
        
        ТекстЗапроса = ТекстЗапроса + "
        |ИЗ
        |  " + ПолноеИмя + " КАК Т";
        
        Если ЗначениеЗаполнено(Фильтр) Тогда
                ТекстЗапроса = ТекстЗапроса + "
                |ГДЕ " + Фильтр;
        КонецЕсли;
        
        Запрос = Новый Запрос;
        Запрос.Текст = ТекстЗапроса;
        
        РезультатЗапроса = Запрос.Выполнить();
        Выборка = РезультатЗапроса.Выбрать();
        
        Строки = Новый Массив;
        Счётчик = 0;
        Номер = 0;
        Пока Выборка.Следующий() Цикл
                Номер = Номер + 1;
                Если Номер <= Пропустить Тогда Продолжить; КонецЕсли;
                Если Счётчик >= Топ Тогда Прервать; КонецЕсли;
                
                Строка = Новый Соответствие;
                Для Каждого Кол Из РезультатЗапроса.Колонки Цикл
                        Строка.Вставить(Кол.Имя, ЗначениеДляJSON(Выборка[Кол.Имя]));
                КонецЦикла;
                Строки.Добавить(Строка);
                Счётчик = Счётчик + 1;
        КонецЦикла;
        
        Возврат ОбъектВJSONКомпакт(Строки);
        
КонецФункции

Функция Инструмент_FindByCode(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        Код = Аргументы["code"];
        
        Части = РазобратьПолноеИмя(ПолноеИмя);
        Если Части = Неопределено Тогда
                Возврат "Некорректное полное имя: " + ПолноеИмя;
        КонецЕсли;
        
        Менеджер = ПолучитьМенеджерОбъекта(Части.Тип, Части.Имя);
        Если Менеджер = Неопределено Тогда
                Возврат "Не удалось получить менеджер для: " + ПолноеИмя;
        КонецЕсли;
        
        Ссылка = Менеджер.НайтиПоКоду(Код);
        Если Не ЗначениеЗаполнено(Ссылка) Тогда

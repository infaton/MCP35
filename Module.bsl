        Св.Вставить("type", "integer");
        Св.Вставить("description", Описание);
        Возврат Св;
КонецФункции

Функция СвойствоБулево(Описание)
        Св = Новый Соответствие;
        Св.Вставить("type", "boolean");
        Св.Вставить("description", Описание);

#Область ОбработкаHTTPЗапросов

// Основной обработчик POST-запроса HTTP-сервиса.
// Имя функции должно совпадать с именем обработчика метода POST в Конфигураторе.
//
Функция ОбработатьЗапрос(Запрос)
        
        Попытка
                ТелоСтрока = Запрос.ПолучитьТелоКакСтроку(КодировкаТекста.UTF8);
        Исключение
                Возврат СформироватьОтветОшибки(-32700, "Parse error: не удалось прочитать тело запроса");
        КонецПопытки;
        
        Если ПустаяСтрока(ТелоСтрока) Тогда
                Возврат СформироватьОтветОшибки(-32700, "Parse error: пустое тело запроса");
        КонецЕсли;
        
        Попытка
                ЧтениеJSON = Новый ЧтениеJSON;
                ЧтениеJSON.УстановитьСтроку(ТелоСтрока);
                ДанныеЗапроса = ПрочитатьJSON(ЧтениеJSON, Истина);
                ЧтениеJSON.Закрыть();
        Исключение
                Возврат СформироватьОтветОшибки(-32700, "Parse error: некорректный JSON");
        КонецПопытки;
        
        Если ТипЗнч(ДанныеЗапроса) <> Тип("Соответствие") Тогда
                Возврат СформироватьОтветОшибки(-32600, "Invalid Request: ожидается JSON-объект");
        КонецЕсли;
        
        Метод = ДанныеЗапроса["method"];
        Если Метод = Неопределено Тогда
                Возврат СформироватьОтветОшибки(-32600, "Invalid Request: отсутствует поле method");
        КонецЕсли;
        
        ИдЗапроса = ДанныеЗапроса["id"];
        Параметры = ДанныеЗапроса["params"];
        Если Параметры = Неопределено Тогда
                Параметры = Новый Соответствие;
        КонецЕсли;
        
        // --- Диспетчеризация методов MCP ---
        
        Если Метод = "initialize" Тогда
                Возврат СформироватьОтветУспех(ИдЗапроса, ПолучитьИнфоСервера());
                
        ИначеЕсли Метод = "tools/list" Тогда
                Результат = Новый Соответствие;
                Результат.Вставить("tools", ПолучитьСписокИнструментов());
                Возврат СформироватьОтветУспех(ИдЗапроса, Результат);
                
        ИначеЕсли Метод = "tools/call" Тогда
                Возврат ОбработатьВызовИнструмента(ИдЗапроса, Параметры);
                
        ИначеЕсли Метод = "ping" Тогда
                Возврат СформироватьОтветУспех(ИдЗапроса, Новый Соответствие);
                
        Иначе
                Возврат СформироватьОтветОшибки(-32601, "Method not found: " + Метод, ИдЗапроса);
        КонецЕсли;
        
КонецФункции

Функция ПолучитьИнфоСервера()
        Результат = Новый Соответствие;
        Результат.Вставить("protocolVersion", "2024-11-05");
        
        Возможности = Новый Соответствие;
        Возможности.Вставить("tools", Новый Соответствие);
        Результат.Вставить("capabilities", Возможности);
        
        Инфо = Новый Соответствие;
        Инфо.Вставить("name", "infaton-1c-mcp");
        Инфо.Вставить("version", "2.1.0");
        Результат.Вставить("serverInfo", Инфо);
        
        Возврат Результат;
КонецФункции

Функция ОбработатьВызовИнструмента(ИдЗапроса, Параметры)
        
        ИмяИнструмента = Параметры["name"];
        Аргументы = Параметры["arguments"];
        Если Аргументы = Неопределено Тогда
                Аргументы = Новый Соответствие;
        КонецЕсли;
        
        Ошибка = Ложь;
        ТекстРезультата = "";
        
        Попытка
                // === Группа А: Метаданные ===
                Если ИмяИнструмента = "get_metadata_tree" Тогда
                        ТекстРезультата = Инструмент_GetMetadataTree(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_object_metadata" Тогда
                        ТекстРезультата = Инструмент_GetObjectMetadata(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_object_attributes" Тогда
                        ТекстРезультата = Инструмент_GetObjectAttributes(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_object_tabular_sections" Тогда
                        ТекстРезультата = Инструмент_GetObjectTabularSections(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_enum_values" Тогда
                        ТекстРезультата = Инструмент_GetEnumValues(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_register_dimensions" Тогда
                        ТекстРезультата = Инструмент_GetRegisterDimensions(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_document_movements" Тогда
                        ТекстРезультата = Инструмент_GetDocumentMovements(Аргументы);
                ИначеЕсли ИмяИнструмента = "search_metadata" Тогда
                        ТекстРезультата = Инструмент_SearchMetadata(Аргументы);
                
                // === Группа Б: Чтение данных ===
                ИначеЕсли ИмяИнструмента = "execute_query" Тогда
                        ТекстРезультата = Инструмент_ExecuteQuery(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_object_by_ref" Тогда
                        ТекстРезультата = Инструмент_GetObjectByRef(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_list" Тогда
                        ТекстРезультата = Инструмент_GetList(Аргументы);
                ИначеЕсли ИмяИнструмента = "find_by_code" Тогда
                        ТекстРезультата = Инструмент_FindByCode(Аргументы);
                ИначеЕсли ИмяИнструмента = "find_by_name" Тогда
                        ТекстРезультата = Инструмент_FindByName(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_register_records" Тогда
                        ТекстРезультата = Инструмент_GetRegisterRecords(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_document_list" Тогда
                        ТекстРезультата = Инструмент_GetDocumentList(Аргументы);
                
                // === Группа В: Запись данных ===
                ИначеЕсли ИмяИнструмента = "create_object" Тогда
                        ТекстРезультата = Инструмент_CreateObject(Аргументы);
                ИначеЕсли ИмяИнструмента = "update_object" Тогда
                        ТекстРезультата = Инструмент_UpdateObject(Аргументы);
                ИначеЕсли ИмяИнструмента = "delete_object" Тогда
                        ТекстРезультата = Инструмент_DeleteObject(Аргументы);
                ИначеЕсли ИмяИнструмента = "post_document" Тогда
                        ТекстРезультата = Инструмент_PostDocument(Аргументы);
                ИначеЕсли ИмяИнструмента = "unpost_document" Тогда
                        ТекстРезультата = Инструмент_UnpostDocument(Аргументы);
                ИначеЕсли ИмяИнструмента = "copy_object" Тогда
                        ТекстРезультата = Инструмент_CopyObject(Аргументы);
                ИначеЕсли ИмяИнструмента = "set_attribute" Тогда
                        ТекстРезультата = Инструмент_SetAttribute(Аргументы);
                
                // === Группа Г: Код и отчёты ===
                ИначеЕсли ИмяИнструмента = "execute_code" Тогда
                        ТекстРезультата = Инструмент_ExecuteCode(Аргументы);
                ИначеЕсли ИмяИнструмента = "evaluate_expression" Тогда
                        ТекстРезультата = Инструмент_EvaluateExpression(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_module_text" Тогда
                        ТекстРезультата = Инструмент_GetModuleText(Аргументы);
                ИначеЕсли ИмяИнструмента = "generate_report" Тогда
                        ТекстРезультата = Инструмент_GenerateReport(Аргументы);
                
                // === Группа Д: Администрирование ===
                ИначеЕсли ИмяИнструмента = "get_active_users" Тогда
                        ТекстРезультата = Инструмент_GetActiveUsers(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_event_log" Тогда
                        ТекстРезультата = Инструмент_GetEventLog(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_locks" Тогда
                        ТекстРезультата = Инструмент_GetLocks(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_server_info" Тогда
                        ТекстРезультата = Инструмент_GetServerInfo(Аргументы);
                ИначеЕсли ИмяИнструмента = "check_references" Тогда
                        ТекстРезультата = Инструмент_CheckReferences(Аргументы);
                ИначеЕсли ИмяИнструмента = "run_scheduled_job" Тогда
                        ТекстРезультата = Инструмент_RunScheduledJob(Аргументы);
                
                // === Группа Е: Интеграция ===
                ИначеЕсли ИмяИнструмента = "exchange_execute" Тогда
                        ТекстРезультата = Инструмент_ExchangeExecute(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_exchange_log" Тогда
                        ТекстРезультата = Инструмент_GetExchangeLog(Аргументы);
                ИначеЕсли ИмяИнструмента = "import_data" Тогда
                        ТекстРезультата = Инструмент_ImportData(Аргументы);
                
                // === Группа Ж: Новые инструменты v2.0 ===
                ИначеЕсли ИмяИнструмента = "fill_on_basis" Тогда
                        ТекстРезультата = Инструмент_FillOnBasis(Аргументы);
                ИначеЕсли ИмяИнструмента = "write_register_records" Тогда
                        ТекстРезультата = Инструмент_WriteRegisterRecords(Аргументы);
                ИначеЕсли ИмяИнструмента = "update_tabular_section" Тогда
                        ТекстРезультата = Инструмент_UpdateTabularSection(Аргументы);
                ИначеЕсли ИмяИнструмента = "subscribe_events" Тогда
                        ТекстРезультата = Инструмент_SubscribeEvents(Аргументы);
                ИначеЕсли ИмяИнструмента = "execute_batch" Тогда
                        ТекстРезультата = Инструмент_ExecuteBatch(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_changes_since" Тогда
                        ТекстРезультата = Инструмент_GetChangesSince(Аргументы);
                
                
                // === Группа З: Новые инструменты v2.1 ===
                ИначеЕсли ИмяИнструмента = "get_balance" Тогда
                        ТекстРезультата = Инструмент_GetBalance(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_register_totals" Тогда
                        ТекстРезультата = Инструмент_GetRegisterTotals(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_accounting_entries" Тогда
                        ТекстРезультата = Инструмент_GetAccountingEntries(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_related_documents" Тогда
                        ТекстРезультата = Инструмент_GetRelatedDocuments(Аргументы);
                ИначеЕсли ИмяИнструмента = "validate_document" Тогда
                        ТекстРезультата = Инструмент_ValidateDocument(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_form_structure" Тогда
                        ТекстРезультата = Инструмент_GetFormStructure(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_rights" Тогда
                        ТекстРезультата = Инструмент_GetRights(Аргументы);
                ИначеЕсли ИмяИнструмента = "find_duplicates" Тогда
                        ТекстРезультата = Инструмент_FindDuplicates(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_print_form" Тогда
                        ТекстРезультата = Инструмент_GetPrintForm(Аргументы);
                ИначеЕсли ИмяИнструмента = "get_configuration_extensions" Тогда
                        ТекстРезультата = Инструмент_GetConfigurationExtensions(Аргументы);

                Иначе
                        Возврат СформироватьОтветОшибки(-32602, "Unknown tool: " + ИмяИнструмента, ИдЗапроса);
                КонецЕсли;
                
        Исключение
                ТекстРезультата = "ОШИБКА: " + ОписаниеОшибки();
                Ошибка = Истина;
        КонецПопытки;
        
        // Формируем MCP-ответ
        Элемент = Новый Соответствие;
        Элемент.Вставить("type", "text");
        Элемент.Вставить("text", ТекстРезультата);
        
        Контент = Новый Массив;
        Контент.Добавить(Элемент);
        
        Результат = Новый Соответствие;
        Результат.Вставить("content", Контент);
        Если Ошибка Тогда
                Результат.Вставить("isError", Истина);
        КонецЕсли;
        
        Возврат СформироватьОтветУспех(ИдЗапроса, Результат);
        
КонецФункции

#КонецОбласти


// ============================================================================
#Область ФормированиеJSON
// ============================================================================

Функция СформироватьОтветУспех(ИдЗапроса, Результат)
        Ответ = Новый Соответствие;
        Ответ.Вставить("jsonrpc", "2.0");
        Ответ.Вставить("id", ИдЗапроса);
        Ответ.Вставить("result", Результат);
        Возврат HTTPОтвет(ОбъектВJSON(Ответ));
КонецФункции

Функция СформироватьОтветОшибки(КодОшибки, Сообщение, ИдЗапроса = Неопределено)
        Ошибка = Новый Соответствие;
        Ошибка.Вставить("code", КодОшибки);
        Ошибка.Вставить("message", Сообщение);
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("jsonrpc", "2.0");
        Ответ.Вставить("id", ИдЗапроса);
        Ответ.Вставить("error", Ошибка);
        Возврат HTTPОтвет(ОбъектВJSON(Ответ));
КонецФункции

Функция HTTPОтвет(ТелоJSON)
        Ответ = Новый HTTPСервисОтвет(200);
        Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
        Ответ.УстановитьТелоИзСтроки(ТелоJSON, КодировкаТекста.UTF8, ИспользованиеByteOrderMark.НеИспользовать);
        Возврат Ответ;
КонецФункции

Функция ОбъектВJSON(Объект)
        ЗаписьJSON = Новый ЗаписьJSON;
        НастройкиСериализации = Новый ПараметрыЗаписиJSON(ПереносСтрокJSON.Нет, , , , , , , Истина);
        ЗаписьJSON.УстановитьСтроку(НастройкиСериализации);
        ЗаписатьJSON(ЗаписьJSON, Объект);
        Возврат ЗаписьJSON.Закрыть();
КонецФункции

Функция ОбъектВJSONКомпакт(Объект)
        ЗаписьJSON = Новый ЗаписьJSON;
        ЗаписьJSON.УстановитьСтроку();
        ЗаписатьJSON(ЗаписьJSON, Объект);
        Возврат ЗаписьJSON.Закрыть();
КонецФункции

#КонецОбласти



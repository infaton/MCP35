                        Возврат ОбъектВJSONКомпакт(Результат);
                Исключение
                        Возврат Строка(Результат);
                КонецПопытки;
        КонецЕсли;
        
КонецФункции

Функция Инструмент_GetModuleText(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        ТипМодуля = Аргументы["module_type"];
        Если Не ЗначениеЗаполнено(ТипМодуля) Тогда
                ТипМодуля = "ОбъектМодуль";
        КонецЕсли;
        
        МДОбъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
        Если МДОбъект = Неопределено Тогда
                Возврат "Объект метаданных не найден: " + ПолноеИмя;
        КонецЕсли;
        
        // Попытка получить текст модуля через встроенные средства
        // Это работает только в привилегированном режиме с отключённым безопасным режимом
        Попытка
                ОбъектМД = РасширенияКонфигурации.Получить(МДОбъект);
                // Альтернативный способ через код
                Код = "
                |МДОбъект = Метаданные.НайтиПоПолномуИмени(""" + ПолноеИмя + """);
                |Результат = 'Получение текста модуля " + ТипМодуля + " для ' + МДОбъект.ПолноеИмя() + ' не поддерживается в runtime. Используйте Конфигуратор или EDT.'";
                Возврат "Получение текста модуля " + ТипМодуля + " для " + ПолноеИмя + " не поддерживается в runtime HTTP-сервиса. Используйте Конфигуратор или EDT для просмотра модулей.";
        Исключение
                Возврат "Получение текста модуля " + ТипМодуля + " для " + ПолноеИмя + " не поддерживается в runtime HTTP-сервиса. Используйте Конфигуратор или EDT для просмотра модулей. Ошибка: " + ОписаниеОшибки();
        КонецПопытки;
        
КонецФункции

Функция Инструмент_GenerateReport(Аргументы)
        
        ТекстЗапроса = Аргументы["query"];
        ФорматВывода = Аргументы["format"];
        Если Не ЗначениеЗаполнено(ФорматВывода) Тогда
                ФорматВывода = "text";
        КонецЕсли;
        
        Запрос = Новый Запрос;
        Запрос.Текст = ТекстЗапроса;
        РезультатЗапроса = Запрос.Выполнить();
        
        Если ФорматВывода = "json" Тогда
                Выборка = РезультатЗапроса.Выбрать();
                Строки = Новый Массив;
                Пока Выборка.Следующий() Цикл
                        Строка = Новый Соответствие;
                        Для Каждого Кол Из РезультатЗапроса.Колонки Цикл
                                Строка.Вставить(Кол.Имя, ЗначениеДляJSON(Выборка[Кол.Имя]));
                        КонецЦикла;
                        Строки.Добавить(Строка);
                КонецЦикла;
                Возврат ОбъектВJSONКомпакт(Строки);
        Иначе
                // Текстовый формат
                Выборка = РезультатЗапроса.Выбрать();
                Текст = "";
                
                // Заголовки
                Заголовки = Новый Массив;
                Для Каждого Кол Из РезультатЗапроса.Колонки Цикл
                        Заголовки.Добавить(Кол.Имя);
                КонецЦикла;
                Текст = СтрСоединить(Заголовки, " | ") + Символы.ПС;
                Текст = Текст + СтрПовторить("—", СтрДлина(Текст)) + Символы.ПС;
                
                // Данные
                Пока Выборка.Следующий() Цикл
                        Значения = Новый Массив;
                        Для Каждого Кол Из РезультатЗапроса.Колонки Цикл
                                Значения.Добавить(Строка(Выборка[Кол.Имя]));
                        КонецЦикла;
                        Текст = Текст + СтрСоединить(Значения, " | ") + Символы.ПС;
                КонецЦикла;
                
                Возврат Текст;
        КонецЕсли;
        
КонецФункции

#КонецОбласти



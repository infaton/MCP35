// G1: Создание объекта на основании другого (цепочки документов)
// Использует типовой механизм ЗаполнитьНаОсновании() платформы 1С
//
Функция Инструмент_FillOnBasis(Аргументы)
        
        ЦелевойТип = Аргументы["target_type"];
        ТипОснования = Аргументы["base_type"];
        GUIDОснования = Аргументы["base_guid"];
        ДопРеквизиты = Аргументы["attributes"];
        
        // Получаем ссылку на объект-основание
        ЧастиОснования = РазобратьПолноеИмя(ТипОснования);
        Если ЧастиОснования = Неопределено Тогда
                Возврат "Некорректное имя основания: " + ТипОснования;
        КонецЕсли;
        
        МенеджерОснования = ПолучитьМенеджерОбъекта(ЧастиОснования.Тип, ЧастиОснования.Имя);
        Если МенеджерОснования = Неопределено Тогда
                Возврат "Не удалось получить менеджер для: " + ТипОснования;
        КонецЕсли;
        
        УИДОснования = Новый УникальныйИдентификатор(GUIDОснования);
        СсылкаОснования = МенеджерОснования.ПолучитьСсылку(УИДОснования);
        
	// v2.1: ПолучитьСсылку() всегда непустая, проверяем реальное существование
	Если СсылкаОснования.ПолучитьОбъект() = Неопределено Тогда
		Возврат "Объект-основание не существует в базе: " + ТипОснования + " / " + GUIDОснования;
        
        // Создаём целевой объект
        ЧастиЦели = РазобратьПолноеИмя(ЦелевойТип);
        Если ЧастиЦели = Неопределено Тогда
                Возврат "Некорректное имя целевого типа: " + ЦелевойТип;
        КонецЕсли;
        
        Если ЧастиЦели.Тип = "Справочник" Тогда
                НовыйОбъект = Справочники[ЧастиЦели.Имя].СоздатьЭлемент();
        ИначеЕсли ЧастиЦели.Тип = "Документ" Тогда
                НовыйОбъект = Документы[ЧастиЦели.Имя].СоздатьДокумент();
        Иначе
                Возврат "Создание на основании поддерживается только для справочников и документов";
        КонецЕсли;
        
        // Вызываем типовой механизм заполнения на основании
        Попытка
                НовыйОбъект.Заполнить(СсылкаОснования);
        Исключение
                // Некоторые объекты не поддерживают Заполнить() — пробуем ЗаполнитьНаОсновании()
                Попытка
                        ДанныеЗаполнения = Новый Структура;
                        ДанныеЗаполнения.Вставить("Основание", СсылкаОснования);
                        НовыйОбъект.Заполнить(ДанныеЗаполнения);
                Исключение
                        Возврат "Ошибка заполнения на основании: " + ОписаниеОшибки();
                КонецПопытки;
        КонецПопытки;
        
        // Переопределяем реквизиты, если указаны
        Если ТипЗнч(ДопРеквизиты) = Тип("Соответствие") Тогда
                ЗаполнитьРеквизитыОбъекта(НовыйОбъект, ДопРеквизиты, ЦелевойТип);
        КонецЕсли;
        
        // Записываем
        НовыйОбъект.Записать();
        
        // Формируем результат
        Результат = Новый Соответствие;
        Результат.Вставить("success", Истина);
        Результат.Вставить("guid", Строка(НовыйОбъект.Ссылка.УникальныйИдентификатор()));
        Результат.Вставить("target_type", ЦелевойТип);
        Результат.Вставить("base_type", ТипОснования);
        Результат.Вставить("base_guid", GUIDОснования);
        Попытка Результат.Вставить("number", НовыйОбъект.Номер); Исключение КонецПопытки;
        Попытка Результат.Вставить("code", НовыйОбъект.Код); Исключение КонецПопытки;
        Попытка Результат.Вставить("date", Формат(НовыйОбъект.Дата, "ДФ=yyyy-MM-ddTHH:mm:ss")); Исключение КонецПопытки;
        
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции


// G2: Запись в регистр сведений напрямую
// Поддерживает периодические и непериодические регистры
//
Функция Инструмент_WriteRegisterRecords(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        Записи = Аргументы["records"];
        Заменять = Аргументы["replace"];
        ПериодСтрока = Аргументы["period"];
        
        Если Заменять = Неопределено Тогда Заменять = Ложь; КонецЕсли;
        
        Части = РазобратьПолноеИмя(ПолноеИмя);
        Если Части = Неопределено Тогда
                Возврат "Некорректное полное имя: " + ПолноеИмя;
        КонецЕсли;
        
        Если Части.Тип <> "РегистрСведений" Тогда
                Возврат "Инструмент поддерживает только РегистрСведений. Получено: " + Части.Тип;
        КонецЕсли;
        
        Если ТипЗнч(Записи) <> Тип("Массив") Тогда
                Возврат "Параметр records должен быть массивом";
        КонецЕсли;
        
        МенеджерЗаписей = РегистрыСведений[Части.Имя];
        МДРегистр = Метаданные.РегистрыСведений[Части.Имя];
        
        ЭтоПериодический = (МДРегистр.ПериодичностьРегистраСведений <> Метаданные.СвойстваОбъектов.ПериодичностьРегистраСведений.Непериодический);
        
        Записано = 0;
        Ошибок = 0;
        ОшибкиТекст = Новый Массив;
        
        Для Каждого ДанныеЗаписи Из Записи Цикл
                Попытка
                        НабЗап = МенеджерЗаписей.СоздатьНаборЗаписей();
                        
                        // Устанавливаем отбор по измерениям
                        Для Каждого Изм Из МДРегистр.Измерения Цикл
                                Если ДанныеЗаписи[Изм.Имя] <> Неопределено Тогда
                                        ЗначениеИзм = ПреобразоватьЗначениеДляРегистра(Изм, ДанныеЗаписи[Изм.Имя]);
                                        НабЗап.Отбор[Изм.Имя].Установить(ЗначениеИзм);
                                КонецЕсли;
                        КонецЦикла;
                        
                        // Период
                        Если ЭтоПериодический Тогда
                                ДатаПериода = Неопределено;
                                Если ДанныеЗаписи["Период"] <> Неопределено Тогда
                                        ДатаПериода = ПреобразоватьДату(ДанныеЗаписи["Период"]);
                                ИначеЕсли ПериодСтрока <> Неопределено И Не ПустаяСтрока(ПериодСтрока) Тогда
                                        ДатаПериода = ПреобразоватьДату(ПериодСтрока);
                                Иначе
                                        ДатаПериода = ТекущаяДатаСеанса();
                                КонецЕсли;
                                НабЗап.Отбор.Период.Установить(ДатаПериода);
                        КонецЕсли;
                        
                        // Читаем существующие записи если режим замены
                        Если Заменять Тогда
                                НабЗап.Прочитать();
                                НабЗап.Очистить();
                        КонецЕсли;
                        
                        // Добавляем новую запись
                        НоваяЗапись = НабЗап.Добавить();
                        
                        // Заполняем период
                        Если ЭтоПериодический И ДатаПериода <> Неопределено Тогда
                                НоваяЗапись.Период = ДатаПериода;
                        КонецЕсли;
                        
                        // Заполняем измерения, ресурсы и реквизиты
                        Для Каждого КЗ Из ДанныеЗаписи Цикл
                                Если КЗ.Ключ = "Период" Тогда Продолжить; КонецЕсли;
                                Попытка
                                        НоваяЗапись[КЗ.Ключ] = ПреобразоватьЗначениеПоМетаданным(МДРегистр, КЗ.Ключ, КЗ.Значение);
                                Исключение
                                        Попытка
                                                НоваяЗапись[КЗ.Ключ] = КЗ.Значение;
                                        Исключение
                                        КонецПопытки;
                                КонецПопытки;
                        КонецЦикла;
                        
                        НабЗап.Записать(Заменять);
                        Записано = Записано + 1;
                        
                Исключение
                        Ошибок = Ошибок + 1;
                        ОшибкиТекст.Добавить(ОписаниеОшибки());
                КонецПопытки;
        КонецЦикла;
        
        Результат = Новый Соответствие;
        Результат.Вставить("success", Ошибок = 0);
        Результат.Вставить("written", Записано);
        Результат.Вставить("errors", Ошибок);
        Если ОшибкиТекст.Количество() > 0 Тогда
                Результат.Вставить("error_details", ОшибкиТекст);
        КонецЕсли;
        
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции


// G3: Обновление табличной части существующего объекта
// Три режима: replace (полная замена), append (добавление), update_by_index (точечное обновление)
//
Функция Инструмент_UpdateTabularSection(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        СтрокаGUID = Аргументы["guid"];
        ИмяТЧ = Аргументы["tabular_section"];
        Строки = Аргументы["rows"];
        Режим = Аргументы["mode"];
        
        Если Режим = Неопределено Или ПустаяСтрока(Режим) Тогда Режим = "replace"; КонецЕсли;
        
        // Получаем объект
        Части = РазобратьПолноеИмя(ПолноеИмя);
        Если Части = Неопределено Тогда
                Возврат "Некорректное полное имя: " + ПолноеИмя;
        КонецЕсли;
        
        Менеджер = ПолучитьМенеджерОбъекта(Части.Тип, Части.Имя);
        Если Менеджер = Неопределено Тогда
                Возврат "Не удалось получить менеджер для: " + ПолноеИмя;
        КонецЕсли;
        
        УИД = Новый УникальныйИдентификатор(СтрокаGUID);
        Ссылка = Менеджер.ПолучитьСсылку(УИД);
        Объект = Ссылка.ПолучитьОбъект();
        
        Если Объект = Неопределено Тогда
                Возврат "Объект не найден: " + СтрокаGUID;
        КонецЕсли;
        
        // Проверяем существование ТЧ
        Попытка
                ТЧОбъекта = Объект[ИмяТЧ];
        Исключение
                Возврат "Табличная часть не найдена: " + ИмяТЧ;
        КонецПопытки;
        
        Если ТипЗнч(Строки) <> Тип("Массив") Тогда
                Возврат "Параметр rows должен быть массивом";
        КонецЕсли;
        
        // Режим replace — очищаем и заполняем заново
        Если Режим = "replace" Тогда
                Объект[ИмяТЧ].Очистить();
                Для Каждого СтрокаДанных Из Строки Цикл
                        НоваяСтрока = Объект[ИмяТЧ].Добавить();
                        Если ТипЗнч(СтрокаДанных) = Тип("Соответствие") Тогда
                                Для Каждого Кол Из СтрокаДанных Цикл
                                        Попытка
                                                УстановитьЗначениеРеквизита(НоваяСтрока, Кол.Ключ, Кол.Значение);
                                        Исключение
                                        КонецПопытки;
                                КонецЦикла;
                        КонецЕсли;
                КонецЦикла;
                
        // Режим append — только добавляем
        ИначеЕсли Режим = "append" Тогда
                Для Каждого СтрокаДанных Из Строки Цикл
                        НоваяСтрока = Объект[ИмяТЧ].Добавить();
                        Если ТипЗнч(СтрокаДанных) = Тип("Соответствие") Тогда
                                Для Каждого Кол Из СтрокаДанных Цикл
                                        Попытка
                                                УстановитьЗначениеРеквизита(НоваяСтрока, Кол.Ключ, Кол.Значение);
                                        Исключение
                                        КонецПопытки;
                                КонецЦикла;
                        КонецЕсли;
                КонецЦикла;
                
        // Режим update_by_index — обновляем конкретные строки по НомерСтроки
        ИначеЕсли Режим = "update_by_index" Тогда
                Для Каждого СтрокаДанных Из Строки Цикл
                        Если ТипЗнч(СтрокаДанных) <> Тип("Соответствие") Тогда Продолжить; КонецЕсли;
                        НомерСтроки = СтрокаДанных["НомерСтроки"];
                        Если НомерСтроки = Неопределено Тогда НомерСтроки = СтрокаДанных["row_index"]; КонецЕсли;
                        Если НомерСтроки = Неопределено Тогда Продолжить; КонецЕсли;
                        
                        Если НомерСтроки < 1 Или НомерСтроки > Объект[ИмяТЧ].Количество() Тогда Продолжить; КонецЕсли;
                        
                        ТекСтрока = Объект[ИмяТЧ][НомерСтроки - 1];
                        Для Каждого Кол Из СтрокаДанных Цикл
                                Если Кол.Ключ = "НомерСтроки" Или Кол.Ключ = "row_index" Тогда Продолжить; КонецЕсли;
                                Попытка
                                        УстановитьЗначениеРеквизита(ТекСтрока, Кол.Ключ, Кол.Значение);
                                Исключение
                                КонецПопытки;
                        КонецЦикла;
                КонецЦикла;
        Иначе
                Возврат "Неизвестный режим: " + Режим + ". Допустимые: replace, append, update_by_index";
        КонецЕсли;
        
        Объект.Записать();
        
        Результат = Новый Соответствие;
        Результат.Вставить("success", Истина);
        Результат.Вставить("guid", СтрокаGUID);
        Результат.Вставить("tabular_section", ИмяТЧ);
        Результат.Вставить("mode", Режим);
        Результат.Вставить("rows_count", Объект[ИмяТЧ].Количество());
        
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции


// G4: Получение событий из журнала регистрации (polling-based CDC)
// Возвращает события с watermark для следующего запроса
//
Функция Инструмент_SubscribeEvents(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        ТипыСобытий = Аргументы["event_types"];
        МеткаС = Аргументы["since"];
        МаксСобытий = Аргументы["max_events"];
        
        Если МаксСобытий = Неопределено Или МаксСобытий = 0 Тогда МаксСобытий = 100; КонецЕсли;
        Если МаксСобытий > 1000 Тогда МаксСобытий = 1000; КонецЕсли;
        
        // Определяем начальную дату
        ДатаНачала = Неопределено;
        Если МеткаС <> Неопределено И Не ПустаяСтрока(МеткаС) Тогда
                ДатаНачала = ПреобразоватьДату(МеткаС);
        КонецЕсли;
        
        Если ДатаНачала = Неопределено Тогда
                ДатаНачала = ТекущаяДатаСеанса() - 300; // 5 минут назад
        КонецЕсли;
        
        ДатаОкончания = ТекущаяДатаСеанса();
        
        // Фильтр по типам событий
        ОтборСобытий = Новый Массив;
        Если ТипыСобытий <> Неопределено И Не ПустаяСтрока(ТипыСобытий) Тогда
                Части = СтрРазделить(ТипыСобытий, ",");
                Для Каждого Ч Из Части Цикл
                        ОтборСобытий.Добавить(СокрЛП(Ч));
                КонецЦикла;
        КонецЕсли;
        
        // Фильтр журнала регистрации
        Отбор = Новый Структура;
        Отбор.Вставить("ДатаНачала", ДатаНачала);
        Отбор.Вставить("ДатаОкончания", ДатаОкончания);
        
        Если ОтборСобытий.Количество() > 0 Тогда
                Отбор.Вставить("Событие", ОтборСобытий);
        КонецЕсли;
        
        // Читаем журнал регистрации
        СобытияЖР = Новый ТаблицаЗначений;
        ВыгрузитьЖурналРегистрации(СобытияЖР, Отбор, , , МаксСобытий);
        
        // Фильтруем по типу объекта (если указан)
        СобытияМассив = Новый Массив;
        МаксДата = ДатаНачала;
        
        Для Каждого СтрокаЖР Из СобытияЖР Цикл
                
                // Фильтр по полному имени
                Если ПолноеИмя <> Неопределено И Не ПустаяСтрока(ПолноеИмя) Тогда
                        Попытка
                                МДОбъекта = СтрокаЖР.МетаданныеПредставление;
                                Если СтрНайти(МДОбъекта, ПолноеИмя) = 0 Тогда Продолжить; КонецЕсли;
                        Исключение
                                Продолжить;
                        КонецПопытки;
                КонецЕсли;
                
                Событие = Новый Соответствие;
                Событие.Вставить("timestamp", Формат(СтрокаЖР.Дата, "ДФ=yyyy-MM-ddTHH:mm:ss"));
                Событие.Вставить("event", Строка(СтрокаЖР.Событие));
                Событие.Вставить("metadata", СтрокаЖР.МетаданныеПредставление);
                Событие.Вставить("user", СтрокаЖР.ИмяПользователя);
                Событие.Вставить("comment", СтрокаЖР.Комментарий);
                
                Попытка
                        Событие.Вставить("data_presentation", СтрокаЖР.ДанныеПредставление);
                Исключение
                КонецПопытки;
                
                СобытияМассив.Добавить(Событие);
                
                Если СтрокаЖР.Дата > МаксДата Тогда
                        МаксДата = СтрокаЖР.Дата;
                КонецЕсли;
                
        КонецЦикла;
        
        Результат = Новый Соответствие;
        Результат.Вставить("events", СобытияМассив);
        Результат.Вставить("count", СобытияМассив.Количество());
        Результат.Вставить("watermark", Формат(МаксДата + 1, "ДФ=yyyy-MM-ddTHH:mm:ss"));
        Результат.Вставить("period_from", Формат(ДатаНачала, "ДФ=yyyy-MM-ddTHH:mm:ss"));
        Результат.Вставить("period_to", Формат(ДатаОкончания, "ДФ=yyyy-MM-ddTHH:mm:ss"));
        
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции


// G5: Пакетное выполнение нескольких операций за один HTTP-вызов
// Поддерживает режимы: последовательный, stop-on-error, транзакционный
//
Функция Инструмент_ExecuteBatch(Аргументы)
        
        Операции = Аргументы["operations"];

	// v2.1: Защита от рекурсии и зависания
	Если ТипЗнч(Операции) = Тип("Массив") Тогда
		Для Каждого ОпПроверка Из Операции Цикл
			Если ОпПроверка["tool"] = "execute_batch" Тогда
				Возврат "Рекурсивный вызов execute_batch запрещён";
			КонецЕсли;
		 КонецЦикла;
	КонецЕсли;

        ОстановкаПоОшибке = Аргументы["stop_on_error"];
        Транзакционный = Аргументы["transactional"];
        
        Если ОстановкаПоОшибке = Неопределено Тогда ОстановкаПоОшибке = Истина; КонецЕсли;
        Если Транзакционный = Неопределено Тогда Транзакционный = Ложь; КонецЕсли;
        
        Если ТипЗнч(Операции) <> Тип("Массив") Тогда
                Возврат "Параметр operations должен быть массивом";
        КонецЕсли;
        
        Если Операции.Количество() = 0 Тогда
                Возврат "Пустой массив операций";
        КонецЕсли;
        
        Если Операции.Количество() > 50 Тогда
                Возврат "Максимальное кол-во операций в пакете: 50";
        КонецЕсли;
        
        Результаты = Новый Массив;
        Успешно = 0;
        Ошибок = 0;
        БылаОшибка = Ложь;
        
        Если Транзакционный Тогда
                НачатьТранзакцию();
        КонецЕсли;
        
        Попытка
                
                Для Каждого Операция Из Операции Цикл
                        
                        ИмяИнструмента = Операция["tool"];
                        АргументыОп = Операция["arguments"];
                        Если АргументыОп = Неопределено Тогда АргументыОп = Новый Соответствие; КонецЕсли;
                        
                        РезОперации = Новый Соответствие;
                        РезОперации.Вставить("tool", ИмяИнструмента);
                        
                        Если БылаОшибка И ОстановкаПоОшибке Тогда
                                РезОперации.Вставить("skipped", Истина);
                                Результаты.Добавить(РезОперации);
                                Продолжить;
                        КонецЕсли;
                        
                        Попытка
                                ТекстРезультата = ВыполнитьИнструментПоИмени(ИмяИнструмента, АргументыОп);
                                РезОперации.Вставить("success", Истина);
                                РезОперации.Вставить("result", ТекстРезультата);
                                Успешно = Успешно + 1;
                        Исключение
                                РезОперации.Вставить("success", Ложь);
                                РезОперации.Вставить("error", ОписаниеОшибки());
                                Ошибок = Ошибок + 1;
                                БылаОшибка = Истина;
                        КонецПопытки;
                        
                        Результаты.Добавить(РезОперации);
                        
                КонецЦикла;
                
                Если Транзакционный Тогда
                        Если БылаОшибка Тогда
                                ОтменитьТранзакцию();
                        Иначе
                                ЗафиксироватьТранзакцию();
                        КонецЕсли;
                КонецЕсли;
                
        Исключение
                Если Транзакционный И ТранзакцияАктивна() Тогда
                        ОтменитьТранзакцию();
                КонецЕсли;
                
                Возврат "Критическая ошибка batch: " + ОписаниеОшибки();
        КонецПопытки;
        
        Итог = Новый Соответствие;
        Итог.Вставить("total", Операции.Количество());
        Итог.Вставить("succeeded", Успешно);
        Итог.Вставить("failed", Ошибок);
        Итог.Вставить("transactional", Транзакционный);
        Итог.Вставить("results", Результаты);
        
        Возврат ОбъектВJSONКомпакт(Итог);
        
КонецФункции


// G6: Получение изменённых объектов с момента watermark (Change Data Capture)
// Использует журнал регистрации для определения изменений
//
Функция Инструмент_GetChangesSince(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        МеткаС = Аргументы["since"];
        ВключитьДанные = Аргументы["include_data"];
        МаксРезультатов = Аргументы["max_results"];
        
        Если ВключитьДанные = Неопределено Тогда ВключитьДанные = Ложь; КонецЕсли;
        Если МаксРезультатов = Неопределено Или МаксРезультатов = 0 Тогда МаксРезультатов = 500; КонецЕсли;
        Если МаксРезультатов > 5000 Тогда МаксРезультатов = 5000; КонецЕсли;
        
        ДатаС = ПреобразоватьДату(МеткаС);
        Если ДатаС = Неопределено Тогда
                Возврат "Некорректная дата since: " + МеткаС;
        КонецЕсли;
        
        // Определяем тип объекта
        Части = РазобратьПолноеИмя(ПолноеИмя);
        Если Части = Неопределено Тогда
                Возврат "Некорректное полное имя: " + ПолноеИмя;
        КонецЕсли;
        
        // Читаем журнал регистрации
        Отбор = Новый Структура;
        Отбор.Вставить("ДатаНачала", ДатаС);
        Отбор.Вставить("ДатаОкончания", ТекущаяДатаСеанса());
        
        // Фильтр по типам событий (запись, проведение, удаление)
        ТипыСобытий = Новый Массив;
        ТипыСобытий.Добавить("_ОбъектЗапись");
        ТипыСобытий.Добавить("_ОбъектПроведение");
        ТипыСобытий.Добавить("_ОбъектУдаление");
        ТипыСобытий.Добавить("_ОбъектОтменаПроведения");
        Отбор.Вставить("Событие", ТипыСобытий);
        
        ТЗ = Новый ТаблицаЗначений;
        ВыгрузитьЖурналРегистрации(ТЗ, Отбор, , , МаксРезультатов * 2); // берём с запасом для фильтрации
        
        // Фильтруем по типу объекта и группируем по GUID
        Изменения = Новый Соответствие; // GUID → последнее изменение
        МаксДата = ДатаС;
        
        Для Каждого СтрокаЖР Из ТЗ Цикл
                Попытка
                        МДПредставление = СтрокаЖР.МетаданныеПредставление;
                        Если СтрНайти(МДПредставление, ПолноеИмя) = 0 Тогда Продолжить; КонецЕсли;
                Исключение
                        Продолжить;
                КонецПопытки;
                
                // Извлекаем GUID из данных
                GUIDОбъекта = "";
                Попытка
                        Данные = СтрокаЖР.Данные;
                        Если ТипЗнч(Данные) <> Тип("Строка") Тогда
                                Попытка
                                        GUIDОбъекта = Строка(Данные.УникальныйИдентификатор());
                                Исключение
                                        GUIDОбъекта = Строка(Данные);
                                КонецПопытки;
                        Иначе
                                GUIDОбъекта = Данные;
                        КонецЕсли;
                Исключение
                        GUIDОбъекта = СтрокаЖР.ДанныеПредставление;
                КонецПопытки;
                
                Если ПустаяСтрока(GUIDОбъекта) Тогда Продолжить; КонецЕсли;
                
                // Определяем тип изменения
                ТипИзменения = "updated";
                Событие = Строка(СтрокаЖР.Событие);
                Если СтрНайти(Событие, "Удаление") > 0 Тогда
                        ТипИзменения = "deleted";
                ИначеЕсли СтрНайти(Событие, "Проведение") > 0 Тогда
                        ТипИзменения = "posted";
                ИначеЕсли СтрНайти(Событие, "ОтменаПроведения") > 0 Тогда
                        ТипИзменения = "unposted";
                КонецЕсли;
                
                Запись = Новый Соответствие;
                Запись.Вставить("guid", GUIDОбъекта);
                Запись.Вставить("change_type", ТипИзменения);
                Запись.Вставить("timestamp", Формат(СтрокаЖР.Дата, "ДФ=yyyy-MM-ddTHH:mm:ss"));
                Запись.Вставить("user", СтрокаЖР.ИмяПользователя);
                
                Изменения.Вставить(GUIDОбъекта, Запись); // последнее изменение по каждому GUID
                
                Если СтрокаЖР.Дата > МаксДата Тогда
                        МаксДата = СтрокаЖР.Дата;
                КонецЕсли;
        КонецЦикла;
        
        // Собираем массив изменений
        МассивИзменений = Новый Массив;
        Для Каждого КЗ Из Изменения Цикл
                
                Если МассивИзменений.Количество() >= МаксРезультатов Тогда Прервать; КонецЕсли;
                
                Запись = КЗ.Значение;
                
                // Включаем полные данные объекта если запрошено
                Если ВключитьДанные И Запись["change_type"] <> "deleted" Тогда
                        Попытка
                                Менеджер = ПолучитьМенеджерОбъекта(Части.Тип, Части.Имя);
                                УИД = Новый УникальныйИдентификатор(КЗ.Ключ);
                                СсылкаОбъекта = Менеджер.ПолучитьСсылку(УИД);
                                ОбъектДанных = СсылкаОбъекта.ПолучитьОбъект();
                                Если ОбъектДанных <> Неопределено Тогда
                                        Запись.Вставить("data", СериализоватьОбъект(ОбъектДанных, ПолноеИмя));
                                КонецЕсли;
                        Исключение
                        КонецПопытки;
                КонецЕсли;
                
                МассивИзменений.Добавить(Запись);
                
        КонецЦикла;
        
        Результат = Новый Соответствие;
        Результат.Вставить("full_name", ПолноеИмя);
        Результат.Вставить("changes", МассивИзменений);
        Результат.Вставить("count", МассивИзменений.Количество());
        Результат.Вставить("watermark", Формат(МаксДата + 1, "ДФ=yyyy-MM-ddTHH:mm:ss"));
        Результат.Вставить("since", МеткаС);
        
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции


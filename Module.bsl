Функция Инструмент_CreateObject(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        Реквизиты = Аргументы["attributes"];
        ТабличныеЧасти = Аргументы["tabular_sections"];
        
        Части = РазобратьПолноеИмя(ПолноеИмя);
        Если Части = Неопределено Тогда
                Возврат "Некорректное полное имя: " + ПолноеИмя;
        КонецЕсли;
        
        // Создаём объект
        Если Части.Тип = "Справочник" Тогда
                НовыйОбъект = Справочники[Части.Имя].СоздатьЭлемент();
        ИначеЕсли Части.Тип = "Документ" Тогда
                НовыйОбъект = Документы[Части.Имя].СоздатьДокумент();
        Иначе
                Возврат "Создание поддерживается только для справочников и документов";
        КонецЕсли;
        
        // Заполняем реквизиты
        Если ТипЗнч(Реквизиты) = Тип("Соответствие") Тогда
                ЗаполнитьРеквизитыОбъекта(НовыйОбъект, Реквизиты, ПолноеИмя);
        КонецЕсли;
        
        // Заполняем табличные части
        Если ТипЗнч(ТабличныеЧасти) = Тип("Соответствие") Тогда
                Для Каждого ТЧ Из ТабличныеЧасти Цикл
                        ИмяТЧ = ТЧ.Ключ;
                        СтрокиТЧ = ТЧ.Значение;
                        Если ТипЗнч(СтрокиТЧ) = Тип("Массив") Тогда
                                Для Каждого СтрокаДанных Из СтрокиТЧ Цикл
                                        НоваяСтрока = НовыйОбъект[ИмяТЧ].Добавить();
                                        Если ТипЗнч(СтрокаДанных) = Тип("Соответствие") Тогда
                                                Для Каждого Кол Из СтрокаДанных Цикл
                                                        Попытка
                                                                УстановитьЗначениеРеквизита(НоваяСтрока, Кол.Ключ, Кол.Значение);
                                                        Исключение
                                                        КонецПопытки;
                                                КонецЦикла;
                                        КонецЕсли;
                                КонецЦикла;
                        КонецЕсли;
                КонецЦикла;
        КонецЕсли;
        
        НовыйОбъект.Записать();
        
        Результат = Новый Соответствие;
        Результат.Вставить("success", Истина);
        Результат.Вставить("guid", Строка(НовыйОбъект.Ссылка.УникальныйИдентификатор()));
        Попытка
                Результат.Вставить("code", НовыйОбъект.Код);
        Исключение
        КонецПопытки;
        Попытка
                Результат.Вставить("number", НовыйОбъект.Номер);
        Исключение
        КонецПопытки;
        
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции


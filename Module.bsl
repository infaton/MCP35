Функция Инструмент_ExchangeExecute(Аргументы)
        
        ИмяПланаОбмена = Аргументы["exchange_plan"];
        КодУзла = Аргументы["node_code"];
        
        // Находим узел плана обмена
        МДПлана = Метаданные.ПланыОбмена.Найти(ИмяПланаОбмена);
        Если МДПлана = Неопределено Тогда
                // Выводим список доступных планов обмена
                Список = Новый Массив;
                Для Каждого МД Из Метаданные.ПланыОбмена Цикл
                        Список.Добавить(МД.Имя + " (" + МД.Синоним + ")");
                КонецЦикла;
                Возврат "План обмена '" + ИмяПланаОбмена + "' не найден. Доступные: " + СтрСоединить(Список, ", ");
        КонецЕсли;
        
        // Если указан код узла — находим конкретный узел
        Если ЗначениеЗаполнено(КодУзла) Тогда
                Узел = ПланыОбмена[ИмяПланаОбмена].НайтиПоКоду(КодУзла);
                Если Не ЗначениеЗаполнено(Узел) Тогда
                        Возврат "Узел с кодом '" + КодУзла + "' не найден в плане обмена " + ИмяПланаОбмена;
                КонецЕсли;
        Иначе
                // Берём первый не-ЭтотУзел
                Запрос = Новый Запрос;
                Запрос.Текст = "ВЫБРАТЬ ПЕРВЫЕ 1 Т.Ссылка ИЗ ПланОбмена." + ИмяПланаОбмена + " КАК Т ГДЕ Т.Ссылка <> &ЭтотУзел";
                Запрос.УстановитьПараметр("ЭтотУзел", ПланыОбмена[ИмяПланаОбмена].ЭтотУзел());
                Рез = Запрос.Выполнить();
                Если Рез.Пустой() Тогда
                        Возврат "В плане обмена " + ИмяПланаОбмена + " нет узлов-получателей";
                КонецЕсли;
                Выб = Рез.Выбрать();
                Выб.Следующий();
                Узел = Выб.Ссылка;
        КонецЕсли;
        
        Результат = Новый Соответствие;
        Результат.Вставить("exchange_plan", ИмяПланаОбмена);
        Результат.Вставить("node", Строка(Узел));
        Результат.Вставить("note", "Для полноценного выполнения обмена используйте execute_code с вызовом конкретных обработок обмена вашей конфигурации");
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции

Функция Инструмент_GetExchangeLog(Аргументы)
        
        МаксСтрок = Аргументы["max_rows"];
        Если МаксСтрок = Неопределено Или МаксСтрок = 0 Тогда МаксСтрок = 50; КонецЕсли;
        ПериодС = Аргументы["period_from"];
        
        // Читаем журнал регистрации с фильтром по событиям обмена
        Отбор = Новый Структура;
        Если ЗначениеЗаполнено(ПериодС) Тогда
                Отбор.Вставить("ДатаНачала", Дата(ПериодС + "000000"));
        Иначе
                Отбор.Вставить("ДатаНачала", ТекущаяДата() - 7 * 86400); // 7 дней назад
        КонецЕсли;
        Отбор.Вставить("ДатаОкончания", КонецДня(ТекущаяДата()));
        
        МассивСобытий = Новый Массив;
        МассивСобытий.Добавить("_$Data$_.Post");
        МассивСобытий.Добавить("_$InfoBase$_.EraseData");
        Отбор.Вставить("Событие", МассивСобытий);
        
        СобытияЖурнала = Новый ТаблицаЗначений;
        ВыгрузитьЖурналРегистрации(СобытияЖурнала, Отбор);
        
        Строки = Новый Массив;
        Количество = Мин(МаксСтрок, СобытияЖурнала.Количество());
        Для Инд = 0 По Количество - 1 Цикл
                С = СобытияЖурнала[Инд];
                Эл = Новый Соответствие;
                Эл.Вставить("date", Формат(С.Дата, "ДФ=yyyy-MM-dd HH:mm:ss"));
                Эл.Вставить("event", Строка(С.Событие));
                Эл.Вставить("comment", Строка(С.Комментарий));
                Эл.Вставить("user", Строка(С.ИмяПользователя));
                Строки.Добавить(Эл);
        КонецЦикла;
        
        Возврат ОбъектВJSONКомпакт(Строки);
        
КонецФункции

Функция Инструмент_ImportData(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        Данные = Аргументы["data"];
        ОбновлятьСуществующие = Аргументы["update_existing"];
        
        Части = РазобратьПолноеИмя(ПолноеИмя);
        Если Части = Неопределено Тогда
                Возврат "Некорректное полное имя: " + ПолноеИмя;
        КонецЕсли;
        
        Если ТипЗнч(Данные) <> Тип("Массив") Тогда
                Возврат "Параметр data должен быть массивом JSON-объектов";
        КонецЕсли;
        
        Создано = 0;
        Обновлено = 0;
        Ошибок = 0;
        ОшибкиТекст = Новый Массив;
        
        Для Каждого ЭлементДанных Из Данные Цикл
                Попытка
                        Если ТипЗнч(ЭлементДанных) <> Тип("Соответствие") Тогда
                                Ошибок = Ошибок + 1;
                                Продолжить;
                        КонецЕсли;
                        
                        Менеджер = ПолучитьМенеджерОбъекта(Части.Тип, Части.Имя);
                        
                        // Пробуем найти существующий по коду
                        Объект = Неопределено;
                        Если ОбновлятьСуществующие = Истина И ЭлементДанных["Код"] <> Неопределено Тогда
                                Ссылка = Менеджер.НайтиПоКоду(ЭлементДанных["Код"]);
                                Если ЗначениеЗаполнено(Ссылка) Тогда
                                        Объект = Ссылка.ПолучитьОбъект();
                                КонецЕсли;
                        КонецЕсли;
                        
                        Если Объект = Неопределено Тогда
                                Если Части.Тип = "Справочник" Тогда
                                        Объект = Справочники[Части.Имя].СоздатьЭлемент();
                                ИначеЕсли Части.Тип = "Документ" Тогда
                                        Объект = Документы[Части.Имя].СоздатьДокумент();
                                КонецЕсли;
                                ЗаполнитьРеквизитыОбъекта(Объект, ЭлементДанных, ПолноеИмя);
                                Объект.Записать();
                                Создано = Создано + 1;
                        Иначе
                                ЗаполнитьРеквизитыОбъекта(Объект, ЭлементДанных, ПолноеИмя);
                                Объект.Записать();
                                Обновлено = Обновлено + 1;
                        КонецЕсли;
                        
                Исключение
                        Ошибок = Ошибок + 1;
                        ОшибкиТекст.Добавить(ОписаниеОшибки());
                КонецПопытки;
        КонецЦикла;
        
        Результат = Новый Соответствие;
        Результат.Вставить("created", Создано);
        Результат.Вставить("updated", Обновлено);
        Результат.Вставить("errors", Ошибок);
        Если ОшибкиТекст.Количество() > 0 Тогда
                Результат.Вставить("error_details", ОшибкиТекст);
        КонецЕсли;
        
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции

#КонецОбласти


// ============================================================================
#Область ВспомогательныеФункции
// ============================================================================

// Разбирает полное имя вида "Справочник.Номенклатура" на тип и имя
Функция РазобратьПолноеИмя(ПолноеИмя)
        
        Поз = СтрНайти(ПолноеИмя, ".");
        Если Поз = 0 Тогда
                Возврат Неопределено;
        КонецЕсли;
        
        Результат = Новый Структура;
        Результат.Вставить("Тип", Лев(ПолноеИмя, Поз - 1));
        Результат.Вставить("Имя", Сред(ПолноеИмя, Поз + 1));
        Возврат Результат;
        
КонецФункции

// Возвращает менеджер объекта (Справочники[...], Документы[...] и т.д.)
Функция ПолучитьМенеджерОбъекта(Тип, Имя)
        
        Если Тип = "Справочник" Тогда
                Возврат Справочники[Имя];
        ИначеЕсли Тип = "Документ" Тогда
                Возврат Документы[Имя];
        ИначеЕсли Тип = "ПланСчетов" Тогда
                Возврат ПланыСчетов[Имя];
        ИначеЕсли Тип = "ПланВидовХарактеристик" Тогда
                Возврат ПланыВидовХарактеристик[Имя];
        ИначеЕсли Тип = "ПланОбмена" Тогда
                Возврат ПланыОбмена[Имя];
        Иначе
                Возврат Неопределено;
        КонецЕсли;
        
КонецФункции

// Описание реквизита метаданных
Функция ОписаниеРеквизита(Реквизит)
        
        РА = Новый Соответствие;
        РА.Вставить("name", Реквизит.Имя);
        РА.Вставить("synonym", Реквизит.Синоним);
        
        // Тип
        ОписаниеТипа = Реквизит.Тип;
        Типы = Новый Массив;
        Для Каждого Т Из ОписаниеТипа.Типы() Цикл
                Типы.Добавить(Строка(Т));
        КонецЦикла;
        РА.Вставить("types", Типы);
        
        // Длина строки (если есть)
        Попытка
                Если ОписаниеТипа.КвалификаторыСтроки <> Неопределено Тогда
                        РА.Вставить("string_length", ОписаниеТипа.КвалификаторыСтроки.Длина);
                КонецЕсли;
        Исключение
        КонецПопытки;
        
        Возврат РА;
        
КонецФункции

// Преобразование любого значения 1С в JSON-совместимый тип
Функция ЗначениеДляJSON(Значение)
        
        Если Значение = Неопределено Или Значение = NULL Тогда
                Возврат Неопределено;
        КонецЕсли;
        
        ТипЗначения = ТипЗнч(Значение);
        
        Если ТипЗначения = Тип("Строка")
                Или ТипЗначения = Тип("Число")
                Или ТипЗначения = Тип("Булево") Тогда
                Возврат Значение;
                
        ИначеЕсли ТипЗначения = Тип("Дата") Тогда
                Возврат Формат(Значение, "ДФ=yyyy-MM-ddTHH:mm:ss");
                
        ИначеЕсли ТипЗначения = Тип("УникальныйИдентификатор") Тогда
                Возврат Строка(Значение);
        Иначе
                // Для ссылочных типов пытаемся получить представление и UUID
                Попытка
                        МД = Значение.Метаданные();
                        Рез = Новый Соответствие;
                        Рез.Вставить("_ref", Строка(Значение));
                        Рез.Вставить("_type", МД.ПолноеИмя());
                        Попытка
                                Рез.Вставить("_guid", Строка(Значение.УникальныйИдентификатор()));
                        Исключение
                        КонецПопытки;
                        Возврат Рез;
                Исключение
                        Возврат Строка(Значение);
                КонецПопытки;
        КонецЕсли;
        
КонецФункции

// Сериализация объекта 1С (справочник, документ) в Соответствие
Функция СериализоватьОбъект(Объект, ПолноеИмя)
        
        Результат = Новый Соответствие;
        
        МДОбъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
        
        // UUID
        Попытка
                Результат.Вставить("_guid", Строка(Объект.Ссылка.УникальныйИдентификатор()));
        Исключение
        КонецПопытки;
        
        Результат.Вставить("_type", ПолноеИмя);
        
        // Стандартные реквизиты
        Попытка Результат.Вставить("Код", Объект.Код); Исключение КонецПопытки;
        Попытка Результат.Вставить("Наименование", Объект.Наименование); Исключение КонецПопытки;
        Попытка Результат.Вставить("Дата", Формат(Объект.Дата, "ДФ=yyyy-MM-ddTHH:mm:ss")); Исключение КонецПопытки;
        Попытка Результат.Вставить("Номер", Объект.Номер); Исключение КонецПопытки;
        Попытка Результат.Вставить("ПометкаУдаления", Объект.ПометкаУдаления); Исключение КонецПопытки;
        Попытка Результат.Вставить("Проведен", Объект.Проведен); Исключение КонецПопытки;
        Попытка Результат.Вставить("Родитель", ЗначениеДляJSON(Объект.Родитель)); Исключение КонецПопытки;
        Попытка Результат.Вставить("Владелец", ЗначениеДляJSON(Объект.Владелец)); Исключение КонецПопытки;
        
        // Пользовательские реквизиты
        Если МДОбъект <> Неопределено Тогда
                Попытка
                        Для Каждого Рекв Из МДОбъект.Реквизиты Цикл
                                Попытка
                                        Результат.Вставить(Рекв.Имя, ЗначениеДляJSON(Объект[Рекв.Имя]));
                                Исключение
                                КонецПопытки;
                        КонецЦикла;
                Исключение
                КонецПопытки;
                
                // Табличные части
                Попытка
                        Для Каждого ТабЧасть Из МДОбъект.ТабличныеЧасти Цикл
                                СтрокиТЧ = Новый Массив;
                                Для Каждого СтрокаТЧ Из Объект[ТабЧасть.Имя] Цикл
                                        СтрокаДанных = Новый Соответствие;
                                        СтрокаДанных.Вставить("НомерСтроки", СтрокаТЧ.НомерСтроки);
                                        Для Каждого Рекв Из ТабЧасть.Реквизиты Цикл
                                                Попытка
                                                        СтрокаДанных.Вставить(Рекв.Имя, ЗначениеДляJSON(СтрокаТЧ[Рекв.Имя]));
                                                Исключение
                                                КонецПопытки;
                                        КонецЦикла;
                                        СтрокиТЧ.Добавить(СтрокаДанных);
                                КонецЦикла;
                                Результат.Вставить(ТабЧасть.Имя, СтрокиТЧ);
                        КонецЦикла;
                Исключение
                КонецПопытки;
        КонецЕсли;
        
        Возврат Результат;
        
КонецФункции

// Заполнение реквизитов объекта из Соответствия
Процедура ЗаполнитьРеквизитыОбъекта(Объект, Реквизиты, ПолноеИмя)
        
        Для Каждого КЗ Из Реквизиты Цикл
                ИмяРеквизита = КЗ.Ключ;
                Значение = КЗ.Значение;
                
                // Пропускаем служебные поля
                Если СтрНачинаетсяС(ИмяРеквизита, "_") Тогда Продолжить; КонецЕсли;
                
                Попытка
                        УстановитьЗначениеРеквизита(Объект, ИмяРеквизита, Значение);
                Исключение
                КонецПопытки;
        КонецЦикла;
        
КонецПроцедуры

// Установка значения реквизита с преобразованием типов
Процедура УстановитьЗначениеРеквизита(Объект, ИмяРеквизита, Значение)
        
        // Если имя заканчивается на _guid — это ссылочный тип, нужно найти объект
        Если СтрЗаканчиваетсяНа(ИмяРеквизита, "_guid") Тогда
                // Формат: ИмяРеквизита_guid = "UUID", ожидаем что реквизит = ИмяРеквизита
                НастоящееИмя = Лев(ИмяРеквизита, СтрДлина(ИмяРеквизита) - 5);
                // Определяем тип реквизита из метаданных
                МД = Объект.Метаданные();
                Для Каждого Рекв Из МД.Реквизиты Цикл
                        Если Рекв.Имя = НастоящееИмя Тогда
                                Типы = Рекв.Тип.Типы();
                                Если Типы.Количество() > 0 Тогда
                                        ТипСсылки = Типы[0];
                                        МДСсылки = Метаданные.НайтиПоТипу(ТипСсылки);
                                        Если МДСсылки <> Неопределено Тогда
                                                Части = РазобратьПолноеИмя(МДСсылки.ПолноеИмя());
                                                Менеджер = ПолучитьМенеджерОбъекта(Части.Тип, Части.Имя);
                                                Если Менеджер <> Неопределено Тогда
                                                        УИД = Новый УникальныйИдентификатор(Значение);
                                                        Объект[НастоящееИмя] = Менеджер.ПолучитьСсылку(УИД);
                                                        Возврат;
                                                КонецЕсли;
                                        КонецЕсли;
                                КонецЕсли;
                                Прервать;
                        КонецЕсли;
                КонецЦикла;
                Возврат;
        КонецЕсли;
        
        // Обычное присваивание
        Объект[ИмяРеквизита] = Значение;
        
КонецПроцедуры


Функция СтрПовторить(ПовторяемыйФрагмент,КоличествоПовторов) 
МассивПустыхСтрок=новый массив(КоличествоПовторов + 1);	
Результат = СтрСоединить(МассивПустыхСтрок, ПовторяемыйФрагмент); 
Возврат Результат;
КонецФункции


#КонецОбласти


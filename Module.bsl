Функция Инструмент_SearchMetadata(Аргументы)
        
        СтрокаПоиска = НРег(Аргументы["query"]);
        ФильтрТипа = Аргументы["type_filter"];
        
        Найденные = Новый Массив;
        
        // Массив коллекций метаданных для поиска
        Коллекции = Новый Соответствие;
        Если Не ЗначениеЗаполнено(ФильтрТипа) Или НРег(ФильтрТипа) = "справочник" Тогда
                Коллекции.Вставить("Справочник", Метаданные.Справочники);
        КонецЕсли;
        Если Не ЗначениеЗаполнено(ФильтрТипа) Или НРег(ФильтрТипа) = "документ" Тогда
                Коллекции.Вставить("Документ", Метаданные.Документы);
        КонецЕсли;
        Если Не ЗначениеЗаполнено(ФильтрТипа) Или НРег(ФильтрТипа) = "регистр" Тогда
                Коллекции.Вставить("РегистрСведений", Метаданные.РегистрыСведений);
                Коллекции.Вставить("РегистрНакопления", Метаданные.РегистрыНакопления);
                Коллекции.Вставить("РегистрБухгалтерии", Метаданные.РегистрыБухгалтерии);
        КонецЕсли;
        Если Не ЗначениеЗаполнено(ФильтрТипа) Или НРег(ФильтрТипа) = "перечисление" Тогда
                Коллекции.Вставить("Перечисление", Метаданные.Перечисления);
        КонецЕсли;
        Если Не ЗначениеЗаполнено(ФильтрТипа) Или НРег(ФильтрТипа) = "пвх" Тогда
                Коллекции.Вставить("ПланВидовХарактеристик", Метаданные.ПланыВидовХарактеристик);
        КонецЕсли;
        Если Не ЗначениеЗаполнено(ФильтрТипа) Или НРег(ФильтрТипа) = "плансчетов" Тогда
                Коллекции.Вставить("ПланСчетов", Метаданные.ПланыСчетов);
        КонецЕсли;
        
        Для Каждого КЭ Из Коллекции Цикл
                Для Каждого МД Из КЭ.Значение Цикл
                        Если СтрНайти(НРег(МД.Имя), СтрокаПоиска) > 0
                                Или СтрНайти(НРег(МД.Синоним), СтрокаПоиска) > 0 Тогда
                                Эл = Новый Соответствие;
                                Эл.Вставить("full_name", КЭ.Ключ + "." + МД.Имя);
                                Эл.Вставить("name", МД.Имя);
                                Эл.Вставить("synonym", МД.Синоним);
                                Эл.Вставить("type", КЭ.Ключ);
                                Найденные.Добавить(Эл);
                        КонецЕсли;
                КонецЦикла;
        КонецЦикла;
        
        Если Найденные.Количество() = 0 Тогда
                Возврат "Ничего не найдено по запросу: " + Аргументы["query"];
        КонецЕсли;
        
        Возврат ОбъектВJSONКомпакт(Найденные);
        
КонецФункции


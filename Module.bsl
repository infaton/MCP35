Функция Инструмент_GetActiveUsers(Аргументы)
        
        Сеансы = ПолучитьСеансыИнформационнойБазы();
        
        Список = Новый Массив;
        Для Каждого Сеанс Из Сеансы Цикл
		Попытка
			Инфо = Новый Соответствие;
			Инфо.Вставить("session_number", Сеанс.НомерСеанса);
			Попытка
				Инфо.Вставить("user_name", Строка(Сеанс.Пользователь));
			Исключение
				Инфо.Вставить("user_name", "<неизвестен>");
			КонецПопытки;
			Попытка
				Инфо.Вставить("computer_name", Сеанс.ИмяКомпьютера);
			Исключение
				Инфо.Вставить("computer_name", "");
			КонецПопытки;
			Инфо.Вставить("application", Строка(Сеанс.ИмяПриложения));
			Инфо.Вставить("started_at", Формат(Сеанс.НачалоСеанса, "ДФ=yyyy-MM-dd HH:mm:ss"));
			Инфо.Вставить("last_active", Формат(Сеанс.ПоследняяАктивность, "ДФ=yyyy-MM-dd HH:mm:ss"));
			Список.Добавить(Инфо);
		Исключение
			// Пропускаем проблемные сеансы
		КонецПопытки;
        КонецЦикла;
        
        Результат = Новый Соответствие;
        Результат.Вставить("sessions", Список);
        Результат.Вставить("total", Список.Количество());
        Возврат ОбъектВJSONКомпакт(Результат);
        
КонецФункции

Функция Инструмент_GetEventLog(Аргументы)
        
        МаксСтрок = Аргументы["max_rows"];
        Если МаксСтрок = Неопределено Или МаксСтрок = 0 Тогда МаксСтрок = 200; КонецЕсли;
        ПериодС = Аргументы["period_from"];
        ПериодПо = Аргументы["period_to"];
        ФильтрСобытий = Аргументы["event_filter"];
        ФильтрПользователя = Аргументы["user_filter"];
        
        Отбор = Новый Структура;
        
        // Период
        Если ЗначениеЗаполнено(ПериодС) Тогда
		ДатаНач = ПреобразоватьДату(ПериодС);
		Если ДатаНач <> Неопределено Тогда
			Отбор.Вставить("ДатаНачала", ДатаНач);
		Иначе
			Отбор.Вставить("ДатаНачала", НачалоДня(ТекущаяДата()));
		КонецЕсли;
        Иначе
                Отбор.Вставить("ДатаНачала", НачалоДня(ТекущаяДата()));
        КонецЕсли;
        
        Если ЗначениеЗаполнено(ПериодПо) Тогда
		ДатаКон = ПреобразоватьДату(ПериодПо);
		Если ДатаКон <> Неопределено Тогда
			Отбор.Вставить("ДатаОкончания", КонецДня(ДатаКон));
		Иначе
			Отбор.Вставить("ДатаОкончания", КонецДня(ТекущаяДата()));
		КонецЕсли;
        Иначе
                Отбор.Вставить("ДатаОкончания", КонецДня(ТекущаяДата()));
        КонецЕсли;
        
        // Фильтр по событиям
        Если ЗначениеЗаполнено(ФильтрСобытий) Тогда
                МассивСобытий = Новый Массив;
                МассивСобытий.Добавить(ФильтрСобытий);
                Отбор.Вставить("Событие", МассивСобытий);
        КонецЕсли;
        
        СобытияЖурнала = Новый ТаблицаЗначений;
        ВыгрузитьЖурналРегистрации(СобытияЖурнала, Отбор);
        
        // Ограничиваем кол-во
        Строки = Новый Массив;
        Количество = Мин(МаксСтрок, СобытияЖурнала.Количество());
        
        Для Инд = 0 По Количество - 1 Цикл
                СтрокаТЗ = СобытияЖурнала[Инд];
                Эл = Новый Соответствие;
                Эл.Вставить("date", Формат(СтрокаТЗ.Дата, "ДФ=yyyy-MM-dd HH:mm:ss"));
                Эл.Вставить("event", Строка(СтрокаТЗ.Событие));
                Эл.Вставить("level", Строка(СтрокаТЗ.Уровень));
                Эл.Вставить("user", Строка(СтрокаТЗ.ИмяПользователя));
                Эл.Вставить("computer", Строка(СтрокаТЗ.Компьютер));
                Эл.Вставить("comment", Строка(СтрокаТЗ.Комментарий));
			Попытка
				Если СтрокаТЗ.Метаданные <> Неопределено Тогда
					Эл.Вставить("metadata", СтрокаТЗ.Метаданные.ПолноеИмя());
				Иначе
					Эл.Вставить("metadata", "");
				КонецЕсли;
			Исключение
				Эл.Вставить("metadata", Строка(СтрокаТЗ.Метаданные));
			КонецПопытки;
                
                // Фильтр по пользователю (если задан)
                Если ЗначениеЗаполнено(ФильтрПользователя) Тогда
                        Если СтрНайти(НРег(Строка(СтрокаТЗ.ИмяПользователя)), НРег(ФильтрПользователя)) > 0 Тогда
                                Строки.Добавить(Эл);
                        КонецЕсли;
                Иначе
                        Строки.Добавить(Эл);
                КонецЕсли;
        КонецЦикла;
        
        Возврат ОбъектВJSONКомпакт(Строки);
        
КонецФункции


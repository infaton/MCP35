                КонецЦикла;
                Строки.Добавить(Стр);
        КонецЦикла;
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("register", ПолноеИмя);
        Ответ.Вставить("balance_type", ТипОстатков);
        Ответ.Вставить("rows", Строки);
        Ответ.Вставить("count", Строки.Количество());
        Возврат ОбъектВJSON(Ответ);
        
КонецФункции


// #44 — get_accounting_entries: Проводки документа
Функция Инструмент_GetAccountingEntries(Аргументы)
        
        СтрСсылка = Аргументы["document_ref"];
        Если СтрСсылка = Неопределено ИЛИ СтрСсылка = "" Тогда
                ВызватьИсключение "Параметр document_ref обязателен";
        КонецЕсли;
        
        ИмяРегистра = Аргументы["register_name"];
        Если ИмяРегистра = Неопределено ИЛИ ИмяРегистра = "" Тогда
                ИмяРегистра = "Хозрасчетный";
        КонецЕсли;
        
        МДРегистр = Метаданные.РегистрыБухгалтерии.Найти(ИмяРегистра);
        Если МДРегистр = Неопределено Тогда
                ВызватьИсключение "Регистр бухгалтерии не найден: " + ИмяРегистра;
        КонецЕсли;
        
        // Ищем ссылку как GUID
        Ссылка = XMLЗначение(Тип("УникальныйИдентификатор"), СтрСсылка);
        
        // Поиск документа по GUID через все типы документов
        НайденнаяСсылка = Неопределено;
        Для Каждого МДДок Из Метаданные.Документы Цикл
                Попытка
                        НайденнаяСсылка = Документы[МДДок.Имя].ПолучитьСсылку(Ссылка);
                        Если НайденнаяСсылка.ПолучитьОбъект() <> Неопределено Тогда
                                Прервать;
                        КонецЕсли;
                        НайденнаяСсылка = Неопределено;
                Исключение
                        НайденнаяСсылка = Неопределено;
                КонецПопытки;
        КонецЦикла;
        
        Если НайденнаяСсылка = Неопределено Тогда
                ВызватьИсключение "Документ не найден по GUID: " + СтрСсылка;
        КонецЕсли;
        
        // Запрос проводок
        ТекстЗапроса = "ВЫБРАТЬ
        |        СчётДт.Код КАК СчётДт,
        |        СчётКт.Код КАК СчётКт,
        |        Сумма,
        |        Количество,
        |        Содержание,
        |        Период
        |ИЗ РегистрБухгалтерии." + ИмяРегистра + "
        |ГДЕ Регистратор = &Регистратор
        |УПОРЯДОЧИТЬ ПО НомерСтроки";
        
        Запрос = Новый Запрос(ТекстЗапроса);
        Запрос.УстановитьПараметр("Регистратор", НайденнаяСсылка);
        
        Результат = Запрос.Выполнить();
        
        Строки = Новый Массив;
        Выборка = Результат.Выбрать();
        Пока Выборка.Следующий() Цикл
                Стр = Новый Соответствие;
                Стр.Вставить("debit_account", Выборка.СчётДт);
                Стр.Вставить("credit_account", Выборка.СчётКт);
                Стр.Вставить("amount", Выборка.Сумма);
                Стр.Вставить("quantity", Выборка.Количество);
                Стр.Вставить("description", Выборка.Содержание);
                Стр.Вставить("period", ЗначениеДляJSON(Выборка.Период));
                Строки.Добавить(Стр);
        КонецЦикла;
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("document", СтрСсылка);
        Ответ.Вставить("register", ИмяРегистра);
        Ответ.Вставить("entries", Строки);
        Ответ.Вставить("count", Строки.Количество());
        Возврат ОбъектВJSON(Ответ);
        
КонецФункции


// #45 — get_related_documents: Связанные документы
Функция Инструмент_GetRelatedDocuments(Аргументы)
        
        СтрСсылка = Аргументы["document_ref"];
        Если СтрСсылка = Неопределено ИЛИ СтрСсылка = "" Тогда
                ВызватьИсключение "Параметр document_ref обязателен";
        КонецЕсли;
        
        Направление = Аргументы["direction"];
        Если Направление = Неопределено ИЛИ Направление = "" Тогда
                Направление = "both";
        КонецЕсли;
        
        МаксГлубина = Аргументы["max_depth"];
        Если МаксГлубина = Неопределено Тогда
                МаксГлубина = 1;
        КонецЕсли;
        Если МаксГлубина > 5 Тогда
                МаксГлубина = 5;
        КонецЕсли;
        
        // Ищем документ по GUID
        Ссылка = XMLЗначение(Тип("УникальныйИдентификатор"), СтрСсылка);
        НайденнаяСсылка = Неопределено;
        ТипДокумента = "";
        Для Каждого МДДок Из Метаданные.Документы Цикл
                Попытка
                        Кандидат = Документы[МДДок.Имя].ПолучитьСсылку(Ссылка);
                        Если Кандидат.ПолучитьОбъект() <> Неопределено Тогда
                                НайденнаяСсылка = Кандидат;
                                ТипДокумента = МДДок.ПолноеИмя();
                                Прервать;
                        КонецЕсли;
                Исключение
                КонецПопытки;
        КонецЦикла;
        
        Если НайденнаяСсылка = Неопределено Тогда
                ВызватьИсключение "Документ не найден по GUID: " + СтрСсылка;
        КонецЕсли;
        
        Связанные = Новый Массив;
        
        // Прямые связи: документы-основания (backward)
        Если Направление = "backward" ИЛИ Направление = "both" Тогда
                Попытка
                        Объект = НайденнаяСсылка.ПолучитьОбъект();
                        Для Каждого Реквизит Из Объект.Метаданные().Реквизиты Цикл
                                Значение = Объект[Реквизит.Имя];
                                Если ТипЗнч(Значение) <> Неопределено Тогда
                                        ОписаниеТипов = Реквизит.Тип;
                                        Для Каждого МДДок Из Метаданные.Документы Цикл
                                                Если ОписаниеТипов.СодержитТип(Тип("ДокументСсылка." + МДДок.Имя)) Тогда
                                                        Если ТипЗнч(Значение) = Тип("ДокументСсылка." + МДДок.Имя) И ЗначениеЗаполнено(Значение) Тогда
                                                                Элемент = Новый Соответствие;
                                                                Элемент.Вставить("ref", XMLСтрока(Значение.УникальныйИдентификатор()));
                                                                Элемент.Вставить("type", МДДок.ПолноеИмя());
                                                                Элемент.Вставить("presentation", Строка(Значение));
                                                                Элемент.Вставить("direction", "backward");
                                                                Элемент.Вставить("link_attribute", Реквизит.Имя);
                                                                Элемент.Вставить("depth", 1);
                                                                Связанные.Добавить(Элемент);
                                                        КонецЕсли;
                                                КонецЕсли;
                                        КонецЦикла;
                                КонецЕсли;
                        КонецЦикла;
                Исключение
                КонецПопытки;
        КонецЕсли;
        
        // Прямые связи: документы, введённые на основании (forward)
        Если Направление = "forward" ИЛИ Направление = "both" Тогда
                // Используем запрос: ищем документы, у которых реквизиты ссылаются на наш
                Для Каждого МДДок Из Метаданные.Документы Цикл
                        Для Каждого Реквизит Из МДДок.Реквизиты Цикл
                                Если Реквизит.Тип.СодержитТип(ТипЗнч(НайденнаяСсылка)) Тогда
                                        Попытка
                                                ТЗапроса = "ВЫБРАТЬ ПЕРВЫЕ 50 Ссылка ИЗ Документ." + МДДок.Имя 
                                                        + " ГДЕ " + Реквизит.Имя + " = &Основание";
                                                ЗапросСвязей = Новый Запрос(ТЗапроса);
                                                ЗапросСвязей.УстановитьПараметр("Основание", НайденнаяСсылка);
                                                РезультатСвязей = ЗапросСвязей.Выполнить();
                                                ВыборкаСвязей = РезультатСвязей.Выбрать();
                                                Пока ВыборкаСвязей.Следующий() Цикл
                                                        Элемент = Новый Соответствие;
                                                        Элемент.Вставить("ref", XMLСтрока(ВыборкаСвязей.Ссылка.УникальныйИдентификатор()));
                                                        Элемент.Вставить("type", МДДок.ПолноеИмя());
                                                        Элемент.Вставить("presentation", Строка(ВыборкаСвязей.Ссылка));
                                                        Элемент.Вставить("direction", "forward");
                                                        Элемент.Вставить("link_attribute", Реквизит.Имя);
                                                        Элемент.Вставить("depth", 1);
                                                        Связанные.Добавить(Элемент);
                                                КонецЦикла;
                                        Исключение
                                        КонецПопытки;
                                КонецЕсли;
                        КонецЦикла;
                КонецЦикла;
        КонецЕсли;
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("document", СтрСсылка);
        Ответ.Вставить("document_type", ТипДокумента);
        Ответ.Вставить("direction", Направление);
        Ответ.Вставить("related", Связанные);
        Ответ.Вставить("count", Связанные.Количество());
        Возврат ОбъектВJSON(Ответ);
        
КонецФункции


// #46 — validate_document: Проверка заполнения документа
Функция Инструмент_ValidateDocument(Аргументы)
        
        СтрСсылка = Аргументы["document_ref"];
        Если СтрСсылка = Неопределено ИЛИ СтрСсылка = "" Тогда
                ВызватьИсключение "Параметр document_ref обязателен";
        КонецЕсли;
        
        // Ищем документ по GUID
        Ссылка = XMLЗначение(Тип("УникальныйИдентификатор"), СтрСсылка);
        НайденнаяСсылка = Неопределено;
        ТипДокумента = "";
        Для Каждого МДДок Из Метаданные.Документы Цикл
                Попытка
                        Кандидат = Документы[МДДок.Имя].ПолучитьСсылку(Ссылка);
                        Если Кандидат.ПолучитьОбъект() <> Неопределено Тогда
                                НайденнаяСсылка = Кандидат;
                                ТипДокумента = МДДок.ПолноеИмя();
                                Прервать;
                        КонецЕсли;
                Исключение
                КонецПопытки;
        КонецЦикла;
        
        Если НайденнаяСсылка = Неопределено Тогда
                ВызватьИсключение "Документ не найден по GUID: " + СтрСсылка;
        КонецЕсли;
        
        Объект = НайденнаяСсылка.ПолучитьОбъект();
        
        // Проверка заполнения
        Отказ = Ложь;
        Ошибки = Новый Массив;
        
        // Проверяем обязательные реквизиты
        Для Каждого Реквизит Из Объект.Метаданные().Реквизиты Цикл
                Если Реквизит.ПроверкаЗаполнения = ПроверкаЗаполнения.ВыдаватьОшибку Тогда
                        Если НЕ ЗначениеЗаполнено(Объект[Реквизит.Имя]) Тогда
                                Отказ = Истина;
                                Элемент = Новый Соответствие;
                                Элемент.Вставить("field", Реквизит.Имя);
                                Элемент.Вставить("presentation", Реквизит.Представление());
                                Элемент.Вставить("error", "Поле не заполнено");
                                Ошибки.Добавить(Элемент);
                        КонецЕсли;
                КонецЕсли;
        КонецЦикла;
        
        // Проверяем обязательные реквизиты табличных частей
        Для Каждого МДТабЧасть Из Объект.Метаданные().ТабличныеЧасти Цикл
                ТабЧасть = Объект[МДТабЧасть.Имя];
                НомерСтроки = 0;
                Для Каждого Строка Из ТабЧасть Цикл
                        НомерСтроки = НомерСтроки + 1;
                        Для Каждого Реквизит Из МДТабЧасть.Реквизиты Цикл
                                Если Реквизит.ПроверкаЗаполнения = ПроверкаЗаполнения.ВыдаватьОшибку Тогда
                                        Если НЕ ЗначениеЗаполнено(Строка[Реквизит.Имя]) Тогда
                                                Отказ = Истина;
                                                Элемент = Новый Соответствие;
                                                Элемент.Вставить("field", МДТабЧасть.Имя + "[" + НомерСтроки + "]." + Реквизит.Имя);
                                                Элемент.Вставить("presentation", Реквизит.Представление());
                                                Элемент.Вставить("error", "Поле не заполнено в строке " + НомерСтроки);
                                                Ошибки.Добавить(Элемент);
                                        КонецЕсли;
                                КонецЕсли;
                        КонецЦикла;
                КонецЦикла;
        КонецЦикла;
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("document", СтрСсылка);
        Ответ.Вставить("document_type", ТипДокумента);
        Ответ.Вставить("is_valid", НЕ Отказ);
        Ответ.Вставить("errors", Ошибки);
        Ответ.Вставить("error_count", Ошибки.Количество());
        Возврат ОбъектВJSON(Ответ);
        
КонецФункции


// #47 — get_form_structure: Структура управляемой формы
Функция Инструмент_GetFormStructure(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        Если ПолноеИмя = Неопределено ИЛИ ПолноеИмя = "" Тогда
                ВызватьИсключение "Параметр full_name обязателен";
        КонецЕсли;
        
        ИмяФормы = Аргументы["form_name"];
        
        // Находим объект метаданных
        МДОбъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
        Если МДОбъект = Неопределено Тогда
                ВызватьИсключение "Объект метаданных не найден: " + ПолноеИмя;
        КонецЕсли;
        
        // Находим форму
        Если ИмяФормы <> Неопределено И ИмяФормы <> "" Тогда
                МДФорма = МДОбъект.Формы.Найти(ИмяФормы);
                Если МДФорма = Неопределено Тогда
                        ВызватьИсключение "Форма не найдена: " + ИмяФормы;
                КонецЕсли;
        Иначе
                // Берём первую форму (основную)
                Если МДОбъект.Формы.Количество() = 0 Тогда
                        ВызватьИсключение "У объекта нет форм";
                КонецЕсли;
                МДФорма = МДОбъект.Формы.Получить(0);
                ИмяФормы = МДФорма.Имя;
        КонецЕсли;
        
        // Собираем информацию о форме
        РеквизитыФормы = Новый Массив;
        Для Каждого Реквизит Из МДФорма.Реквизиты Цикл
                Элемент = Новый Соответствие;
                Элемент.Вставить("name", Реквизит.Имя);
                Элемент.Вставить("title", Реквизит.Заголовок);
                Попытка
                        Элемент.Вставить("type", Строка(Реквизит.Тип));
                Исключение
                        Элемент.Вставить("type", "Неизвестно");
                КонецПопытки;
                РеквизитыФормы.Добавить(Элемент);
        КонецЦикла;
        
        КомандыФормы = Новый Массив;
        Для Каждого Команда Из МДФорма.Команды Цикл
                Элемент = Новый Соответствие;
                Элемент.Вставить("name", Команда.Имя);
                Элемент.Вставить("title", Команда.Заголовок);
                КомандыФормы.Добавить(Элемент);
        КонецЦикла;
        
        // Список доступных форм объекта
        ВсеФормы = Новый Массив;
        Для Каждого Ф Из МДОбъект.Формы Цикл
                ВсеФормы.Добавить(Ф.Имя);
        КонецЦикла;
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("object", ПолноеИмя);
        Ответ.Вставить("form_name", ИмяФормы);
        Ответ.Вставить("attributes", РеквизитыФормы);
        Ответ.Вставить("attribute_count", РеквизитыФормы.Количество());
        Ответ.Вставить("commands", КомандыФормы);
        Ответ.Вставить("command_count", КомандыФормы.Количество());
        Ответ.Вставить("available_forms", ВсеФормы);
        Возврат ОбъектВJSON(Ответ);
        
КонецФункции


// #48 — get_rights: Права доступа текущего пользователя
Функция Инструмент_GetRights(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        Если ПолноеИмя = Неопределено ИЛИ ПолноеИмя = "" Тогда
                ВызватьИсключение "Параметр full_name обязателен";
        КонецЕсли;
        
        МДОбъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
        Если МДОбъект = Неопределено Тогда
                ВызватьИсключение "Объект метаданных не найден: " + ПолноеИмя;
        КонецЕсли;
        
        Права = Новый Соответствие;
        
        // Базовые права — проверяем через ПравоДоступа
        МассивПрав = Новый Массив;
        МассивПрав.Добавить("Чтение");
        МассивПрав.Добавить("Добавление");
        МассивПрав.Добавить("Изменение");
        МассивПрав.Добавить("Удаление");
        МассивПрав.Добавить("Проведение");
        МассивПрав.Добавить("ОтменаПроведения");
        МассивПрав.Добавить("ИнтерактивноеДобавление");
        МассивПрав.Добавить("ИнтерактивноеИзменение");
        МассивПрав.Добавить("ИнтерактивноеУдаление");
        МассивПрав.Добавить("Просмотр");
        МассивПрав.Добавить("ИнтерактивнаяПометкаУдаления");
        
        Для Каждого ИмяПрава Из МассивПрав Цикл
                Попытка
                        Права.Вставить(ИмяПрава, ПравоДоступа(ИмяПрава, МДОбъект));
                Исключение
                        // Право не применимо к данному объекту — пропускаем
                КонецПопытки;
        КонецЦикла;
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("object", ПолноеИмя);
        Ответ.Вставить("user", Строка(ПользователиИнформационнойБазы.ТекущийПользователь().Имя));
        Ответ.Вставить("rights", Права);
        Ответ.Вставить("is_full_rights", ПривилегированныйРежим());
        Возврат ОбъектВJSON(Ответ);
        
КонецФункции


// #49 — find_duplicates: Поиск дублей в справочниках
Функция Инструмент_FindDuplicates(Аргументы)
        
        ПолноеИмя = Аргументы["full_name"];
        Если ПолноеИмя = Неопределено ИЛИ ПолноеИмя = "" Тогда
                ВызватьИсключение "Параметр full_name обязателен";
        КонецЕсли;
        
        СтрокаРеквизитов = Аргументы["attributes"];
        Если СтрокаРеквизитов = Неопределено ИЛИ СтрокаРеквизитов = "" Тогда
                ВызватьИсключение "Параметр attributes обязателен";
        КонецЕсли;
        
        Порог = Аргументы["threshold"];
        Если Порог = Неопределено Тогда
                Порог = 90;
        КонецЕсли;
        
        МаксРезультатов = Аргументы["max_results"];
        Если МаксРезультатов = Неопределено ИЛИ МаксРезультатов = 0 Тогда
                МаксРезультатов = 100;
        КонецЕсли;
        
        Части = РазобратьПолноеИмя(ПолноеИмя);
        МДОбъект = Метаданные.НайтиПоПолномуИмени(ПолноеИмя);
        Если МДОбъект = Неопределено Тогда
                ВызватьИсключение "Объект метаданных не найден: " + ПолноеИмя;
        КонецЕсли;
        
        // Парсим список реквизитов
        МассивРеквизитов = СтрРазделить(СтрокаРеквизитов, ",", Ложь);
        Для Индекс = 0 По МассивРеквизитов.ВГраница() Цикл
                МассивРеквизитов[Индекс] = СокрЛП(МассивРеквизитов[Индекс]);
        КонецЦикла;
        
        // Формируем запрос — ищем записи с одинаковыми значениями
        ПоляВыборки = "Ссылка";
        Для Каждого ИмяРеквизита Из МассивРеквизитов Цикл
                ПоляВыборки = ПоляВыборки + ", " + ИмяРеквизита;
        КонецЦикла;
        
        // Самосоединение для поиска дублей
        УсловияСравнения = Новый Массив;
        Для Каждого ИмяРеквизита Из МассивРеквизитов Цикл
                УсловияСравнения.Добавить("Т1." + ИмяРеквизита + " = Т2." + ИмяРеквизита);
        КонецЦикла;
        
        ТекстЗапроса = "ВЫБРАТЬ ПЕРВЫЕ " + Формат(МаксРезультатов * 2, "ЧГ=") + "
        |        Т1.Ссылка КАК Ссылка1,
        |        Т2.Ссылка КАК Ссылка2";
        
        Для Каждого ИмяРеквизита Из МассивРеквизитов Цикл
                ТекстЗапроса = ТекстЗапроса + ",
        |        Т1." + ИмяРеквизита + " КАК " + ИмяРеквизита;
        КонецЦикла;
        
        ТекстЗапроса = ТекстЗапроса + "
        |ИЗ " + ПолноеИмя + " КАК Т1
        |        ВНУТРЕННЕЕ СОЕДИНЕНИЕ " + ПолноеИмя + " КАК Т2
        |        ПО " + СтрСоединить(УсловияСравнения, " И ") + "
        |                И Т1.Ссылка < Т2.Ссылка
        |ГДЕ НЕ Т1.ПометкаУдаления И НЕ Т2.ПометкаУдаления";
        
        Запрос = Новый Запрос(ТекстЗапроса);
        Результат = Запрос.Выполнить();
        
        Пары = Новый Массив;
        Выборка = Результат.Выбрать();
        Пока Выборка.Следующий() И Пары.Количество() < МаксРезультатов Цикл
                Пара = Новый Соответствие;
                Пара.Вставить("ref1", ЗначениеДляJSON(Выборка.Ссылка1));
                Пара.Вставить("presentation1", Строка(Выборка.Ссылка1));
                Пара.Вставить("ref2", ЗначениеДляJSON(Выборка.Ссылка2));
                Пара.Вставить("presentation2", Строка(Выборка.Ссылка2));
                ОбщиеПоля = Новый Соответствие;
                Для Каждого ИмяРеквизита Из МассивРеквизитов Цикл
                        ОбщиеПоля.Вставить(ИмяРеквизита, ЗначениеДляJSON(Выборка[ИмяРеквизита]));
                КонецЦикла;
                Пара.Вставить("matching_fields", ОбщиеПоля);
                Пара.Вставить("match_score", 100); // точное совпадение
                Пары.Добавить(Пара);
        КонецЦикла;
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("object", ПолноеИмя);
        Ответ.Вставить("attributes", МассивРеквизитов);
        Ответ.Вставить("duplicates", Пары);
        Ответ.Вставить("count", Пары.Количество());
        Возврат ОбъектВJSON(Ответ);
        
КонецФункции


// #50 — get_print_form: Печатная форма через УправлениеПечатью
Функция Инструмент_GetPrintForm(Аргументы)
        
        СтрСсылка = Аргументы["document_ref"];
        Если СтрСсылка = Неопределено ИЛИ СтрСсылка = "" Тогда
                ВызватьИсключение "Параметр document_ref обязателен";
        КонецЕсли;
        
        ИдПечатнойФормы = Аргументы["print_form_id"];
        
        Формат = Аргументы["format"];
        Если Формат = Неопределено ИЛИ Формат = "" Тогда
                Формат = "info";
        КонецЕсли;
        
        // Ищем документ по GUID
        Ссылка = XMLЗначение(Тип("УникальныйИдентификатор"), СтрСсылка);
        НайденнаяСсылка = Неопределено;
        ТипДокумента = "";
        Для Каждого МДДок Из Метаданные.Документы Цикл
                Попытка
                        Кандидат = Документы[МДДок.Имя].ПолучитьСсылку(Ссылка);
                        Если Кандидат.ПолучитьОбъект() <> Неопределено Тогда
                                НайденнаяСсылка = Кандидат;
                                ТипДокумента = МДДок.ПолноеИмя();
                                Прервать;
                        КонецЕсли;
                Исключение
                КонецПопытки;
        КонецЦикла;
        
        Если НайденнаяСсылка = Неопределено Тогда
                ВызватьИсключение "Документ не найден по GUID: " + СтрСсылка;
        КонецЕсли;
        
        МассивОбъектов = Новый Массив;
        МассивОбъектов.Добавить(НайденнаяСсылка);
        
        // Если ИдПечатнойФормы не указан — возвращаем список доступных форм
        Если ИдПечатнойФормы = Неопределено ИЛИ ИдПечатнойФормы = "" Тогда
                КомандыПечати = Новый Соответствие;
                Попытка
                        ТаблицаКоманд = УправлениеПечатью.КомандыПечатиОбъекта(НайденнаяСсылка.Метаданные());
                        ДоступныеФормы = Новый Массив;
                        Для Каждого Команда Из ТаблицаКоманд Цикл
                                Элемент = Новый Соответствие;
                                Элемент.Вставить("id", Команда.Идентификатор);
                                Элемент.Вставить("presentation", Команда.Представление);
                                ДоступныеФормы.Добавить(Элемент);
                        КонецЦикла;
                        
                        Ответ = Новый Соответствие;
                        Ответ.Вставить("document", СтрСсылка);
                        Ответ.Вставить("document_type", ТипДокумента);
                        Ответ.Вставить("available_forms", ДоступныеФормы);
                        Ответ.Вставить("count", ДоступныеФормы.Количество());
                        Возврат ОбъектВJSON(Ответ);
                Исключение
                        ВызватьИсключение "Не удалось получить список печатных форм: " + ОписаниеОшибки();
                КонецПопытки;
        КонецЕсли;
        
        // Генерируем печатную форму
        Попытка
                КоллекцияПечатныхФорм = УправлениеПечатью.СформироватьПечатныеФормы(
                        ИдПечатнойФормы, 
                        МассивОбъектов);
        Исключение
                ВызватьИсключение "Ошибка формирования печатной формы '" + ИдПечатнойФормы + "': " + ОписаниеОшибки();
        КонецПопытки;
        
        Если КоллекцияПечатныхФорм.Количество() = 0 Тогда
                ВызватьИсключение "Печатная форма не сформирована";
        КонецЕсли;
        
        ТабДокумент = КоллекцияПечатныхФорм[0].ТабличныйДокумент;
        
        Если Формат = "mxl_text" Тогда
                // Текстовое представление табличного документа
                ТекстовыйДокумент = Новый ТекстовыйДокумент;
                Для НомерСтроки = 1 По ТабДокумент.ВысотаТаблицы Цикл
                        СтрокаТекста = "";
                        Для НомерКолонки = 1 По ТабДокумент.ШиринаТаблицы Цикл
                                Область = ТабДокумент.Область(НомерСтроки, НомерКолонки);
                                Текст = СокрЛП(Строка(Область.Текст));
                                Если Текст <> "" Тогда
                                        СтрокаТекста = СтрокаТекста + Текст + " | ";
                                КонецЕсли;
                        КонецЦикла;
                        Если СтрокаТекста <> "" Тогда
                                ТекстовыйДокумент.ДобавитьСтроку(СтрокаТекста);
                        КонецЕсли;
                КонецЦикла;
                
                Ответ = Новый Соответствие;
                Ответ.Вставить("document", СтрСсылка);
                Ответ.Вставить("print_form_id", ИдПечатнойФормы);
                Ответ.Вставить("format", "mxl_text");
                Ответ.Вставить("text", ТекстовыйДокумент.ПолучитьТекст());
                Ответ.Вставить("rows", ТабДокумент.ВысотаТаблицы);
                Ответ.Вставить("columns", ТабДокумент.ШиринаТаблицы);
                Возврат ОбъектВJSON(Ответ);
        Иначе
                // info — мета-описание печатной формы
                Ответ = Новый Соответствие;
                Ответ.Вставить("document", СтрСсылка);
                Ответ.Вставить("print_form_id", ИдПечатнойФормы);
                Ответ.Вставить("format", "info");
                Ответ.Вставить("rows", ТабДокумент.ВысотаТаблицы);
                Ответ.Вставить("columns", ТабДокумент.ШиринаТаблицы);
                Ответ.Вставить("title", КоллекцияПечатныхФорм[0].СинонимМакета);
                Возврат ОбъектВJSON(Ответ);
        КонецЕсли;
        
КонецФункции


// #51 — get_configuration_extensions: Список расширений конфигурации
Функция Инструмент_GetConfigurationExtensions(Аргументы)
        
        ТолькоАктивные = Аргументы["active_only"];
        Если ТолькоАктивные = Неопределено Тогда
                ТолькоАктивные = Истина;
        КонецЕсли;
        
        Расширения = Новый Массив;
        
        Попытка
                Коллекция = РасширенияКонфигурации.Получить();
                Для Каждого Расширение Из Коллекция Цикл
                        Если ТолькоАктивные И НЕ Расширение.Активно Тогда
                                Продолжить;
                        КонецЕсли;
                        
                        Элемент = Новый Соответствие;
                        Элемент.Вставить("name", Расширение.Имя);
                        Элемент.Вставить("synonym", Расширение.Синоним);
                        Элемент.Вставить("version", Расширение.Версия);
                        Элемент.Вставить("active", Расширение.Активно);
                        Элемент.Вставить("safe_mode", Расширение.БезопасныйРежим);
                        Элемент.Вставить("purpose", Строка(Расширение.Назначение));
                        Элемент.Вставить("scope", Строка(Расширение.ОбластьДействия));
                        
                        Попытка
                                Элемент.Вставить("uuid", XMLСтрока(Расширение.УникальныйИдентификатор));
                        Исключение
                                Элемент.Вставить("uuid", "");
                        КонецПопытки;
                        
                        Расширения.Добавить(Элемент);
                КонецЦикла;
        Исключение
                ВызватьИсключение "Не удалось получить список расширений: " + ОписаниеОшибки();
        КонецПопытки;
        
        Ответ = Новый Соответствие;
        Ответ.Вставить("extensions", Расширения);
        Ответ.Вставить("count", Расширения.Количество());
        Ответ.Вставить("active_only", ТолькоАктивные);
        Возврат ОбъектВJSON(Ответ);
        
КонецФункции

#КонецОбласти

#Область ВспомогательныеФункции
